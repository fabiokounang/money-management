<!DOCTYPE html>
<html lang="en">

<head>
	<%- include('../partials/app_head') %>
</head>

<body class="min-h-screen bg-stone-50 text-stone-800">
	<%- include('../partials/sidebar') %>

	<div id="app-overlay" class="app-overlay lg:hidden"></div>

	<main class="app-main px-4 py-4 sm:px-6 sm:py-6">
		<%- include('../partials/topbar') %>

		<%
            const item = typeof category_item !== 'undefined' && category_item ? category_item : {};

            function getTypeBadgeClass(type) {
                return type === 'income'
                    ? 'bg-emerald-100 text-emerald-700'
                    : 'bg-rose-100 text-rose-700';
            }

            function getTypeLabel(type) {
                return type === 'income' ? 'Income' : 'Expense';
            }

            function getStatusBadgeClass(isActive) {
                return Number(isActive) === 1
                    ? 'bg-emerald-100 text-emerald-700'
                    : 'bg-stone-200 text-stone-700';
            }

            function getStatusLabel(isActive) {
                return Number(isActive) === 1 ? 'Active' : 'Inactive';
            }

            function getDisplayIcon(icon) {
                return icon && String(icon).trim() !== '' ? icon : '◎';
            }

            function getDisplayColor(color) {
                return color && String(color).trim() !== '' ? color : '-';
            }

            function getColorSwatchClass(color) {
                const map = {
                    red: 'bg-red-300',
                    orange: 'bg-orange-300',
                    yellow: 'bg-yellow-300',
                    green: 'bg-emerald-300',
                    blue: 'bg-blue-300',
                    purple: 'bg-purple-300',
                    pink: 'bg-pink-300',
                    gray: 'bg-gray-300',
                    grey: 'bg-gray-300',
                    brown: 'bg-amber-700'
                };

                const key = String(color || '').toLowerCase();
                return map[key] || 'bg-stone-300';
            }

        %>

		<section class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1.6fr)_360px]">
			<div>
				<div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50 backdrop-blur">
					<div class="border-b border-stone-100 bg-gradient-to-r from-amber-50 via-white to-emerald-50 px-5 py-5 sm:px-7 sm:py-6">
						<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
							<div>
								<div class="inline-flex items-center gap-2 rounded-full border border-amber-200 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-amber-700 shadow-sm">
									Category
								</div>
								<h1 class="mt-4 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">
									Edit Category
								</h1>
								<p class="mt-2 max-w-2xl text-sm leading-7 text-stone-600">
									Update the category so transactions and reports stay consistent and clear.
								</p>
							</div>

							<a
								href="/category"
								class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-200 hover:text-emerald-700"
							>
								← Back to Categories
							</a>
						</div>
					</div>

					<div class="px-5 py-6 sm:px-7 sm:py-7">
						<% if (typeof error !== 'undefined' && error) { %>
						<div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
							<%= error %>
						</div>
						<% } %>

						<form action="/category/<%= item.id %>?_method=PUT" method="POST" class="space-y-8">
							<div class="rounded-[28px] border border-stone-200 bg-stone-50/70 p-5 sm:p-6">
								<div class="flex items-center gap-3">
									<div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-emerald-100 text-lg text-emerald-700">
										•
									</div>
									<div>
										<h2 class="text-base font-semibold text-stone-900">Basic Information</h2>
										<p class="mt-1 text-sm text-stone-500">
											Update the category’s main identity.
										</p>
									</div>
								</div>

								<div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-2">
									<div>
										<label for="category_name" class="mb-2 block text-sm font-semibold text-stone-800">
											Category Name
										</label>
										<input
											type="text"
											id="category_name"
											name="category_name"
											class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition placeholder:text-stone-400 focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
											placeholder="Example: Food, Salary, Transport"
											maxlength="100"
											value="<%= item.category_name || '' %>"
											required
										>
									</div>

									<div>
										<label for="category_type" class="mb-2 block text-sm font-semibold text-stone-800">
											Category Type
										</label>
										<select
											id="category_type"
											name="category_type"
											class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
											required
										>
											<option value="">Select category type</option>
											<option value="income" <%= item.category_type === 'income' ? 'selected' : '' %>>Income</option>
											<option value="expense" <%= item.category_type === 'expense' ? 'selected' : '' %>>Expense</option>
										</select>
										<p class="mt-2 text-xs leading-5 text-stone-500">
											Income for inflows, expense for outflows.
										</p>
									</div>
								</div>
							</div>

							<div class="rounded-[28px] border border-stone-200 bg-stone-50/70 p-5 sm:p-6">
								<div class="flex items-center gap-3">
									<div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-amber-100 text-lg text-amber-700">
										•
									</div>
									<div>
										<h2 class="text-base font-semibold text-stone-900">Visual Settings</h2>
										<p class="mt-1 text-sm text-stone-500">
											Change icon and color if it helps recognition.
										</p>
									</div>
								</div>

								<div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-2">
									<div>
										<label for="icon" class="mb-2 block text-sm font-semibold text-stone-800">
											Icon
										</label>
										<input
											type="text"
											id="icon"
											name="icon"
											class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition placeholder:text-stone-400 focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
											placeholder="Example: 🍜 or 💼"
											maxlength="100"
											value="<%= item.icon || '' %>"
										>
									</div>

									<div>
										<label for="color" class="mb-2 block text-sm font-semibold text-stone-800">
											Color
										</label>
										<input
											type="text"
											id="color"
											name="color"
											class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition placeholder:text-stone-400 focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
											placeholder="Example: orange, green, blue"
											maxlength="20"
											value="<%= item.color || '' %>"
										>
									</div>
								</div>

								<div class="mt-5 max-w-md">
									<label for="is_active" class="mb-2 block text-sm font-semibold text-stone-800">
										Status
									</label>
									<select
										id="is_active"
										name="is_active"
										class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
										required
									>
										<option value="1" <%= Number(item.is_active) === 1 ? 'selected' : '' %>>Active</option>
										<option value="0" <%= Number(item.is_active) === 0 ? 'selected' : '' %>>Inactive</option>
									</select>
								</div>
							</div>

							<div class="flex flex-col gap-3 border-t border-stone-200 pt-6 sm:flex-row sm:items-center sm:justify-between">
								<button
									type="submit"
									form="delete-category-form"
									class="inline-flex items-center justify-center rounded-2xl border border-rose-200 bg-rose-50 px-5 py-3 text-sm font-semibold text-rose-700 transition hover:bg-rose-100"
								>
									Delete Category
								</button>

								<div class="flex flex-col gap-3 sm:flex-row">
									<a
										href="/category"
										class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-5 py-3 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-stone-300"
									>
										Cancel
									</a>

									<button
										type="submit"
										class="inline-flex items-center justify-center rounded-2xl bg-stone-900 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-stone-300/40 transition hover:-translate-y-0.5 hover:bg-emerald-700"
									>
										Update Category
									</button>
								</div>
							</div>
						</form>

						<form
							id="delete-category-form"
							action="/category/<%= item.id %>?_method=DELETE"
							method="POST"
							onsubmit="return confirm('Delete this category?');"
						></form>
					</div>
				</div>
			</div>

			<div class="space-y-6">
				<div class="rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40 sm:p-6">
					<div class="flex items-center gap-3">
						<div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700">
							✦
						</div>
						<div>
							<p class="text-base font-semibold text-stone-900">Category Meta</p>
							<p class="mt-1 text-sm text-stone-500">Helpful context for this record.</p>
						</div>
					</div>

					<div class="mt-5 space-y-4">
						<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
							<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Category ID</p>
							<p class="mt-2 text-base font-semibold text-stone-900">#CAT-<%= item.id || '-' %></p>
						</div>

						<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
							<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Created At</p>
							<p class="mt-2 text-sm font-semibold text-stone-900"><%= formatDateTimeWib(item.created_at) %></p>
						</div>

						<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
							<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Last Updated</p>
							<p class="mt-2 text-sm font-semibold text-stone-900"><%= formatDateTimeWib(item.updated_at) %></p>
						</div>
					</div>
				</div>

				<div class="rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40 sm:p-6">
					<div class="flex items-center gap-3">
						<div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-amber-100 text-amber-700">
							▣
						</div>
						<div>
							<p class="text-base font-semibold text-stone-900">Preview</p>
							<p class="mt-1 text-sm text-stone-500">How this category currently looks.</p>
						</div>
					</div>

					<div class="mt-5 rounded-[28px] border border-stone-200 bg-gradient-to-br from-stone-900 to-stone-700 p-5 text-white shadow-lg">
						<div class="flex items-start justify-between gap-4">
							<div>
								<div class="flex items-center gap-3">
									<span class="text-xl"><%= getDisplayIcon(item.icon) %></span>
									<h3 class="text-base font-semibold"><%= item.category_name || '-' %></h3>
								</div>
								<p class="mt-2 text-sm text-white/70">Used for transactions and reports</p>
							</div>

							<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= getTypeBadgeClass(item.category_type) %>">
								<%= getTypeLabel(item.category_type) %>
							</span>
						</div>

						<div class="mt-4 flex items-center gap-2">
							<span class="h-4 w-4 rounded-full <%= getColorSwatchClass(item.color) %>"></span>
							<p class="text-sm font-medium text-white"><%= getDisplayColor(item.color) %></p>
						</div>

						<div class="mt-4">
							<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= getStatusBadgeClass(item.is_active) %>">
								<%= getStatusLabel(item.is_active) %>
							</span>
						</div>
					</div>
				</div>

				<div class="rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40 sm:p-6">
					<p class="text-base font-semibold text-stone-900">Editing Note</p>
					<p class="mt-3 text-sm leading-7 text-stone-600">
						Category changes affect how you enter transactions and how reports look.
						Keep names clear and distinct from other categories.
					</p>
				</div>
			</div>
		</section>
	</main>

	<script>
		const sidebarToggle = document.getElementById('sidebar-toggle');
		const sidebar = document.getElementById('app-sidebar');
		const overlay = document.getElementById('app-overlay');

		if (sidebarToggle && sidebar && overlay) {
			sidebarToggle.addEventListener('click', () => {
				sidebar.classList.toggle('show');
				overlay.classList.toggle('show');
			});

			overlay.addEventListener('click', () => {
				sidebar.classList.remove('show');
				overlay.classList.remove('show');
			});
		}
	</script>
</body>

</html>