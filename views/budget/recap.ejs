<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/app_head') %>
</head>
<body class="min-h-screen bg-stone-50 text-stone-800">
  <%- include('../partials/sidebar') %>
  <div id="app-overlay" class="app-overlay lg:hidden"></div>

  <main class="app-main px-4 py-4 sm:px-6 sm:py-6">
    <%- include('../partials/topbar') %>

    <%
      const safeFilters = filters || { from_date: '', to_date: '' };
      const safeRows = Array.isArray(recap_rows) ? recap_rows : [];
      const safeSummary = summary || {
        over_count: 0,
        near_count: 0,
        ok_count: 0,
        quiet_count: 0,
        total_rows: 0,
        total_cap: 0,
        total_spent: 0,
        total_remaining: 0
      };
      const safeInsights = Array.isArray(insights) ? insights : [];

      function formatCurrency(value) {
        return 'Rp ' + Number(value || 0).toLocaleString('id-ID');
      }

      function statusBadgeClass(key) {
        if (key === 'over') return 'bg-rose-100 text-rose-800';
        if (key === 'near') return 'bg-amber-100 text-amber-800';
        if (key === 'quiet') return 'bg-slate-100 text-slate-700';
        if (key === 'na') return 'bg-stone-100 text-stone-600';
        return 'bg-emerald-100 text-emerald-800';
      }

      function periodLabel(pt) {
        if (pt === 'weekly') return 'Weekly';
        if (pt === 'monthly') return 'Monthly';
        if (pt === 'yearly') return 'Yearly';
        if (pt === 'custom') return 'Custom';
        return pt || '—';
      }
    %>

    <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
    <div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">
      <%= success_msg[0] %>
    </div>
    <% } %>

    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
    <div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-800">
      <%= error_msg[0] %>
    </div>
    <% } %>

    <section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
      <div class="border-b border-stone-100 bg-gradient-to-r from-violet-50 via-white to-emerald-50 px-5 py-5 sm:px-7 sm:py-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full border border-violet-200 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-violet-700 shadow-sm">
              Recap
            </div>
            <h1 class="mt-4 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">
              Budget performance
            </h1>
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-stone-600">
              Compare actual spending to each budget limit for the dates you choose (for example a full month at month-end).
              Only <span class="font-semibold text-stone-800">expense</span> transactions in the same category count, dated inside the overlap of the budget window and your filter range.
            </p>
          </div>
          <div class="flex flex-wrap gap-2">
            <a
              href="/budget"
              class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-4 py-2.5 text-sm font-semibold text-stone-800 shadow-sm transition hover:border-stone-300"
            >
              ← Budgets
            </a>
            <a
              href="/report?from_date=<%= encodeURIComponent(safeFilters.from_date) %>&to_date=<%= encodeURIComponent(safeFilters.to_date) %>"
              class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-4 py-2.5 text-sm font-semibold text-stone-800 shadow-sm transition hover:border-stone-300"
            >
              Financial report
            </a>
          </div>
        </div>

        <form method="GET" action="/budget/recap" class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-[1fr_1fr_auto] lg:items-end">
          <div>
            <label class="mb-2 block text-sm font-semibold text-stone-800">From date</label>
            <input
              type="date"
              name="from_date"
              value="<%= safeFilters.from_date %>"
              class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
              required
            >
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold text-stone-800">To date</label>
            <input
              type="date"
              name="to_date"
              value="<%= safeFilters.to_date %>"
              class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
              required
            >
          </div>
          <div class="flex flex-wrap gap-2">
            <button
              type="submit"
              class="inline-flex h-[50px] items-center justify-center rounded-2xl bg-stone-900 px-6 text-sm font-semibold text-white shadow-lg transition hover:bg-emerald-700"
            >
              Apply range
            </button>
            <a
              href="/budget/recap"
              class="inline-flex h-[50px] items-center justify-center rounded-2xl border border-stone-200 bg-white px-5 text-sm font-semibold text-stone-700 shadow-sm hover:border-stone-300"
            >
              This month
            </a>
          </div>
        </form>
      </div>

      <div class="border-b border-stone-100 bg-stone-50/50 px-5 py-5 sm:px-7">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Summary</p>
        <ul class="mt-3 space-y-2 text-sm text-stone-700">
          <% safeInsights.forEach((line) => { %>
          <li class="flex gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500"></span>
            <span><%= line %></span>
          </li>
          <% }) %>
        </ul>
      </div>

      <div class="grid grid-cols-2 gap-3 border-b border-stone-100 px-5 py-5 sm:grid-cols-3 sm:px-7 lg:grid-cols-6">
        <div class="rounded-2xl border border-stone-200 bg-white p-4 shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-stone-500">Budget rows</p>
          <p class="mt-1 text-xl font-bold text-stone-900"><%= safeSummary.total_rows %></p>
        </div>
        <div class="rounded-2xl border border-rose-100 bg-rose-50/60 p-4 shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-rose-700">Over</p>
          <p class="mt-1 text-xl font-bold text-rose-800"><%= safeSummary.over_count %></p>
        </div>
        <div class="rounded-2xl border border-amber-100 bg-amber-50/60 p-4 shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-amber-800">Near ≥80%</p>
          <p class="mt-1 text-xl font-bold text-amber-900"><%= safeSummary.near_count %></p>
        </div>
        <div class="rounded-2xl border border-emerald-100 bg-emerald-50/60 p-4 shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-emerald-800">On track</p>
          <p class="mt-1 text-xl font-bold text-emerald-900"><%= safeSummary.ok_count %></p>
        </div>
        <div class="rounded-2xl border border-slate-100 bg-slate-50 p-4 shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-600">No spending</p>
          <p class="mt-1 text-xl font-bold text-slate-800"><%= safeSummary.quiet_count %></p>
        </div>
        <div class="col-span-2 rounded-2xl border border-stone-200 bg-white p-4 shadow-sm sm:col-span-3 lg:col-span-1">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-stone-500">Actual total</p>
          <p class="mt-1 text-lg font-bold text-stone-900 whitespace-nowrap"><%= formatCurrency(safeSummary.total_spent) %></p>
          <p class="mt-1 text-xs text-stone-500">Limit total: <%= formatCurrency(safeSummary.total_cap) %></p>
        </div>
      </div>

      <div class="overflow-x-auto px-5 py-6 sm:px-7">
        <% if (safeRows.length === 0) { %>
        <p class="py-12 text-center text-sm text-stone-500">No rows to show for this range.</p>
        <% } else { %>
        <table class="min-w-full border-collapse text-left text-sm">
          <thead>
            <tr class="border-b border-stone-200 text-xs font-semibold uppercase tracking-[0.12em] text-stone-500">
              <th class="px-3 py-3">Category</th>
              <th class="px-3 py-3">Budget period</th>
              <th class="px-3 py-3 text-right">Limit</th>
              <th class="px-3 py-3 text-right">Actual (range)</th>
              <th class="px-3 py-3 text-right">Remaining</th>
              <th class="px-3 py-3 text-right">% used</th>
              <th class="px-3 py-3">Status</th>
            </tr>
          </thead>
          <tbody>
            <% safeRows.forEach((row) => { %>
            <tr class="border-b border-stone-100 last:border-b-0 hover:bg-stone-50/80">
              <td class="px-3 py-3 font-semibold text-stone-900">
                <%= row.category_name %>
                <% if (Number(row.is_active) !== 1) { %>
                <span class="ml-2 rounded-full bg-stone-200 px-2 py-0.5 text-[10px] font-semibold uppercase text-stone-600">Inactive</span>
                <% } %>
              </td>
              <td class="px-3 py-3 text-stone-600">
                <span class="font-medium text-stone-800"><%= periodLabel(row.period_type) %></span>
                <br>
                <span class="text-xs text-stone-700"><%= row.budget_period_label || '—' %></span>
                <br>
                <span class="text-[11px] text-violet-700">Counted: <%= row.counted_period_label || '—' %></span>
              </td>
              <td class="px-3 py-3 text-right font-medium whitespace-nowrap"><%= formatCurrency(row.cap) %></td>
              <td class="px-3 py-3 text-right font-medium whitespace-nowrap"><%= formatCurrency(row.spent) %></td>
              <td class="px-3 py-3 text-right whitespace-nowrap <%= row.remaining < 0 ? 'font-semibold text-rose-700' : 'text-stone-800' %>">
                <%= formatCurrency(row.remaining) %>
              </td>
              <td class="px-3 py-3 text-right text-stone-700"><%= row.cap > 0 ? row.pct_used + '%' : '—' %></td>
              <td class="px-3 py-3">
                <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= statusBadgeClass(row.status_key) %>">
                  <%= row.status_label %>
                </span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </section>
  </main>
</body>
</html>
