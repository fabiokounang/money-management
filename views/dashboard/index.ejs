<!DOCTYPE html>
<html lang="en">

<head>
	<%- include('../partials/app_head') %>
	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="min-h-screen bg-stone-50 text-stone-800">
	<%- include('../partials/sidebar') %>

	<div id="app-overlay" class="app-overlay lg:hidden"></div>

	<main class="app-main px-4 py-4 sm:px-6 sm:py-6">
		<%- include('../partials/topbar') %>

		<%
			const safeFilters = filters || { from_date: '', to_date: '' };

			const safeSummary = summary || {
				total_income: 0,
				total_expense: 0,
				total_transfer: 0,
				balance: 0,
				transaction_count: 0
			};

			const safeRecentTransactions = Array.isArray(recent_transactions) ? recent_transactions : [];
			const safeTopCategories = Array.isArray(top_categories) ? top_categories : [];
			const safeMonthlyIncomeExpense = Array.isArray(monthly_income_expense) ? monthly_income_expense : [];
			const safeExpenseByCategory = Array.isArray(expense_by_category) ? expense_by_category : [];
			const safeWeeklyCheckin = weekly_checkin || {
				current_week: {
					from_date: '',
					to_date: '',
					total_income: 0,
					total_expense: 0,
					transaction_count: 0,
					balance: 0
				},
				previous_week: {
					from_date: '',
					to_date: '',
					total_income: 0,
					total_expense: 0,
					transaction_count: 0,
					balance: 0
				},
				expense_delta: 0,
				recommendation: {
					title: 'Keep your weekly check-in',
					message: 'Weekly insights will appear once transactions are available.',
					cta_label: 'Open transactions',
					cta_href: '/transaction'
				}
			};
			const safeActionableInsights = Array.isArray(actionable_insights) ? actionable_insights : [];

			function formatCurrency(value) {
				return 'Rp ' + Number(value || 0).toLocaleString('id-ID');
			}

			function getTypeBadgeClass(type) {
				if (type === 'income') return 'bg-emerald-100 text-emerald-700';
				if (type === 'expense') return 'bg-rose-100 text-rose-700';
				return 'bg-amber-100 text-amber-700';
			}

			function getAmountClass(type) {
				if (type === 'income') return 'text-emerald-700';
				if (type === 'expense') return 'text-rose-700';
				return 'text-stone-800';
			}

			function getAmountPrefix(type) {
				if (type === 'income') return '+ ';
				if (type === 'expense') return '- ';
				return '';
			}

			const highestCategoryTotal = safeTopCategories.length > 0
				? Number(safeTopCategories[0].total || 0)
				: 0;

			const donutLabels = safeExpenseByCategory.map((item) => item.category_name);
			const donutValues = safeExpenseByCategory.map((item) => Number(item.total || 0));

			const trendLabels = safeMonthlyIncomeExpense.map((item) => item.month_label);
			const trendIncomeValues = safeMonthlyIncomeExpense.map((item) => Number(item.total_income || 0));
			const trendExpenseValues = safeMonthlyIncomeExpense.map((item) => Number(item.total_expense || 0));
		%>

		<section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
			<div class="relative overflow-hidden border-b border-stone-100 bg-gradient-to-r from-emerald-50 via-white to-amber-50 px-5 py-6 sm:px-7 sm:py-7">
				<div class="absolute inset-y-0 right-0 hidden w-1/3 bg-[radial-gradient(circle_at_center,rgba(16,185,129,0.10),transparent_60%)] lg:block"></div>

				<div class="relative flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
					<div class="max-w-2xl">
						<div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 shadow-sm">
							Dashboard
						</div>

						<h1 class="mt-4 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">
							Welcome back to your money overview
						</h1>

						<p class="mt-2 text-sm leading-7 text-stone-600">
							Ringkasan keuanganmu untuk periode
							<span class="font-semibold text-stone-800"><%= safeFilters.from_date %></span>
							sampai
							<span class="font-semibold text-stone-800"><%= safeFilters.to_date %></span>.
						</p>

						<form method="GET" action="/dashboard" class="mt-5 rounded-[28px] border border-stone-200/80 bg-white/85 p-4 shadow-sm backdrop-blur">
							<div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-[1fr_1fr_auto_auto]">
								<div class="min-w-0">
									<label class="mb-2 block text-sm font-semibold text-stone-800">From Date</label>
									<input
										type="date"
										name="from_date"
										value="<%= safeFilters.from_date %>"
										class="w-full min-w-0 rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
										required
									>
								</div>

								<div class="min-w-0">
									<label class="mb-2 block text-sm font-semibold text-stone-800">To Date</label>
									<input
										type="date"
										name="to_date"
										value="<%= safeFilters.to_date %>"
										class="w-full min-w-0 rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
										required
									>
								</div>

								<div class="flex items-end">
									<a
										href="/dashboard"
										class="inline-flex h-[50px] w-full items-center justify-center rounded-2xl border border-stone-200 bg-white px-5 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-stone-300 md:w-auto"
									>
										Clear Filter
									</a>
								</div>

								<div class="flex items-end">
									<button
										type="submit"
										class="inline-flex h-[50px] w-full items-center justify-center rounded-2xl bg-stone-900 px-5 text-sm font-semibold text-white shadow-lg shadow-stone-300/30 transition hover:-translate-y-0.5 hover:bg-emerald-700 md:w-auto"
									>
										Apply Filter
									</button>
								</div>
							</div>
						</form>
					</div>

					<!-- <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 xl:w-[360px]">
						<div class="rounded-2xl border border-stone-200 bg-white/90 px-4 py-3 shadow-sm">
							<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Income</p>
							<p class="mt-1 text-sm font-semibold text-emerald-700"><%= formatCurrency(safeSummary.total_income) %></p>
						</div>

						<div class="rounded-2xl border border-stone-200 bg-white/90 px-4 py-3 shadow-sm">
							<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Expense</p>
							<p class="mt-1 text-sm font-semibold text-rose-700"><%= formatCurrency(safeSummary.total_expense) %></p>
						</div>

						<div class="col-span-2 rounded-2xl border border-stone-200 bg-white/90 px-4 py-3 shadow-sm sm:col-span-1">
							<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Balance</p>
							<p class="mt-1 text-sm font-semibold text-stone-900"><%= formatCurrency(safeSummary.balance) %></p>
						</div>
					</div> -->
				</div>
			</div>

			<div class="px-5 py-5 sm:px-7 sm:py-6">
				<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
					<div class="rounded-[28px] border border-stone-200/80 bg-white p-5 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-medium text-stone-500">Total Income</p>
								<h3 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight text-stone-900 whitespace-nowrap">
									<%= formatCurrency(safeSummary.total_income) %>
								</h3>
								<p class="mt-2 text-xs text-emerald-600">For <%= safeFilters.from_date %> until <%= safeFilters.to_date %></p>
							</div>
							<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-lg font-semibold text-emerald-700">↗</div>
						</div>
					</div>

					<div class="rounded-[28px] border border-stone-200/80 bg-white p-5 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-medium text-stone-500">Total Expense</p>
								<h3 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight text-stone-900 whitespace-nowrap">
									<%= formatCurrency(safeSummary.total_expense) %>
								</h3>
								<p class="mt-2 text-xs text-rose-600">For <%= safeFilters.from_date %> until <%= safeFilters.to_date %></p>
							</div>
							<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-rose-100 text-lg font-semibold text-rose-700">↘</div>
						</div>
					</div>

					<div class="rounded-[28px] border border-stone-200/80 bg-white p-5 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-medium text-stone-500">Current Balance</p>
								<h3 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight text-stone-900 whitespace-nowrap">
									<%= formatCurrency(safeSummary.balance) %>
								</h3>
								<p class="mt-2 text-xs text-amber-700">Income minus expense</p>
							</div>
							<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-100 text-lg font-semibold text-amber-700">◎</div>
						</div>
					</div>

					<div class="rounded-[28px] border border-stone-200/80 bg-white p-5 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-medium text-stone-500">Transactions</p>
								<h3 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight text-stone-900 whitespace-nowrap"><%= safeSummary.transaction_count %></h3>
								<p class="mt-2 text-xs text-stone-500">This month activity</p>
							</div>
							<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-stone-200 text-lg font-semibold text-stone-700">▣</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="mt-6 grid grid-cols-1 gap-6 2xl:grid-cols-3">
			<div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/50 sm:p-6">
				<div>
					<p class="text-base font-semibold text-stone-900">Expense Composition</p>
					<p class="mt-1 text-sm text-stone-500">Expense by category for current month</p>
				</div>

				<div class="mt-6 h-[320px] rounded-[24px] border border-stone-200 bg-stone-50 p-4">
					<canvas id="expenseDonutChart"></canvas>
				</div>
			</div>

			<div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/50 sm:p-6 2xl:col-span-2">
				<div>
					<p class="text-base font-semibold text-stone-900">Income vs Expense Trend</p>
					<p class="mt-1 text-sm text-stone-500">Last 6 months from real transaction data</p>
				</div>

				<div class="mt-6 h-[320px] rounded-[24px] border border-stone-200 bg-stone-50 p-4">
					<canvas id="incomeExpenseBarChart"></canvas>
				</div>
			</div>
		</section>

		<section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
			<div class="border-b border-stone-100 bg-gradient-to-r from-indigo-50 via-white to-rose-50 px-5 py-5 sm:px-7 sm:py-6">
				<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
					<div>
						<p class="text-base font-semibold text-stone-900">Weekly Check-In</p>
						<p class="mt-1 text-sm text-stone-500">
							<%= safeWeeklyCheckin.current_week.from_date %> - <%= safeWeeklyCheckin.current_week.to_date %>
						</p>
					</div>
					<a
						href="/transaction?from_date=<%= encodeURIComponent(safeWeeklyCheckin.current_week.from_date || '') %>&to_date=<%= encodeURIComponent(safeWeeklyCheckin.current_week.to_date || '') %>"
						class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-4 py-2 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-stone-300"
					>
						Open week details
					</a>
				</div>
			</div>

			<div class="px-5 py-6 sm:px-7 sm:py-7">
				<div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
					<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
						<p class="text-xs uppercase tracking-[0.14em] text-stone-500">This Week Income</p>
						<p class="mt-2 text-base font-bold text-blue-700 whitespace-nowrap"><%= formatCurrency(safeWeeklyCheckin.current_week.total_income) %></p>
					</div>
					<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
						<p class="text-xs uppercase tracking-[0.14em] text-stone-500">This Week Expense</p>
						<p class="mt-2 text-base font-bold text-rose-700 whitespace-nowrap"><%= formatCurrency(safeWeeklyCheckin.current_week.total_expense) %></p>
					</div>
					<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
						<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Weekly Balance</p>
						<p class="mt-2 text-base font-bold text-stone-900 whitespace-nowrap"><%= formatCurrency(safeWeeklyCheckin.current_week.balance) %></p>
					</div>
					<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
						<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Expense vs Last Week</p>
						<p class="mt-2 text-base font-bold <%= Number(safeWeeklyCheckin.expense_delta || 0) > 0 ? 'text-rose-700' : 'text-emerald-700' %> whitespace-nowrap">
							<%= Number(safeWeeklyCheckin.expense_delta || 0) > 0 ? '+' : '' %><%= formatCurrency(safeWeeklyCheckin.expense_delta) %>
						</p>
					</div>
				</div>

				<div class="mt-5 rounded-[28px] border border-indigo-100 bg-gradient-to-r from-indigo-50/70 to-rose-50/70 p-5">
					<p class="text-sm font-semibold text-stone-900"><%= safeWeeklyCheckin.recommendation.title %></p>
					<p class="mt-2 text-sm leading-7 text-stone-600"><%= safeWeeklyCheckin.recommendation.message %></p>
					<a
						href="<%= safeWeeklyCheckin.recommendation.cta_href %>"
						class="mt-4 inline-flex items-center justify-center rounded-2xl bg-stone-900 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-emerald-700"
					>
						<%= safeWeeklyCheckin.recommendation.cta_label %>
					</a>
				</div>
			</div>
		</section>

		<section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
			<div class="border-b border-stone-100 bg-gradient-to-r from-violet-50 via-white to-sky-50 px-5 py-5 sm:px-7 sm:py-6">
				<p class="text-base font-semibold text-stone-900">Actionable Insights</p>
				<p class="mt-1 text-sm text-stone-500">Small next steps based on your latest financial pattern.</p>
			</div>

			<div class="px-5 py-6 sm:px-7 sm:py-7">
				<div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
					<% if (safeActionableInsights.length === 0) { %>
					<div class="xl:col-span-3 rounded-[24px] border border-stone-200 bg-stone-50 p-4 text-sm text-stone-500">
						No insights yet. Add more transactions to unlock personalized recommendations.
					</div>
					<% } %>

					<% safeActionableInsights.forEach((insight) => { %>
					<div class="rounded-[24px] border border-stone-200 bg-white p-4 shadow-sm">
						<p class="text-sm font-semibold text-stone-900"><%= insight.title %></p>
						<p class="mt-2 text-sm leading-7 text-stone-600"><%= insight.message %></p>
						<a
							href="<%= insight.cta_href %>"
							class="mt-4 inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-stone-50 px-4 py-2 text-sm font-semibold text-stone-700 transition hover:-translate-y-0.5 hover:border-stone-300"
						>
							<%= insight.cta_label %>
						</a>
					</div>
					<% }) %>
				</div>
			</div>
		</section>

		<section class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-3">
			<div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50 xl:col-span-2">
				<div class="flex items-center justify-between gap-4 border-b border-stone-100 px-5 py-5 sm:px-7 sm:py-6">
					<div>
						<p class="text-base font-semibold text-stone-900">Recent Transactions</p>
						<p class="mt-1 text-sm text-stone-500">Latest money movements from your database</p>
					</div>

					<a href="/transaction" class="text-sm font-semibold text-emerald-700 hover:underline">
						View all
					</a>
				</div>

				<div class="px-5 py-6 sm:px-7 sm:py-7">
					<div class="space-y-4">
						<% if (safeRecentTransactions.length === 0) { %>
						<div class="rounded-[24px] border border-stone-200 bg-stone-50 p-4 text-sm text-stone-500">
							No transactions found yet. Start by creating your first transaction.
						</div>
						<% } %>

						<% safeRecentTransactions.forEach((item) => { %>
						<div class="flex flex-col gap-3 rounded-[28px] border border-stone-200 bg-white p-4 shadow-sm sm:flex-row sm:items-center sm:justify-between">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl text-base font-bold <%= getTypeBadgeClass(item.transaction_type) %>">
									<%= item.transaction_type === 'income' ? '↗' : item.transaction_type === 'expense' ? '↘' : '◎' %>
								</div>
								<div>
									<p class="font-semibold text-stone-900"><%= item.description || item.category_name || 'No description' %></p>
									<p class="text-sm text-stone-500">
										<%= item.category_name || '-' %> • <%= formatDateWib(item.transaction_date) %> • <%= item.account_name || '-' %>
									</p>
								</div>
							</div>
							<div class="sm:text-right">
								<p class="text-sm font-semibold <%= getAmountClass(item.transaction_type) %> whitespace-nowrap">
									<%= getAmountPrefix(item.transaction_type) %><%= formatCurrency(item.amount) %>
								</p>
							</div>
						</div>
						<% }) %>
					</div>
				</div>
			</div>

			<div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/50 sm:p-6">
				<div>
					<p class="text-base font-semibold text-stone-900">Top Categories</p>
					<p class="mt-1 text-sm text-stone-500">Highest expense categories this month</p>
				</div>

				<div class="mt-6 space-y-5">
					<% if (safeTopCategories.length === 0) { %>
					<div class="rounded-[24px] border border-stone-200 bg-stone-50 p-4 text-sm text-stone-500">
						No expense category data available yet.
					</div>
					<% } %>

					<% safeTopCategories.forEach((item) => { %>
					<%
                        const itemTotal = Number(item.total || 0);
                        const percentage = highestCategoryTotal > 0
                            ? Math.max((itemTotal / highestCategoryTotal) * 100, 6)
                            : 0;
                    %>

					<div>
						<div class="mb-2 flex items-center justify-between gap-4">
							<p class="text-sm font-semibold text-stone-900"><%= item.category_name %></p>
							<p class="text-sm text-stone-500 whitespace-nowrap"><%= formatCurrency(item.total) %></p>
						</div>
						<div class="h-2.5 overflow-hidden rounded-full bg-stone-100">
							<span class="block h-full rounded-full bg-gradient-to-r from-emerald-400 to-emerald-600" style="width: <%= percentage %>%;"></span>
						</div>
					</div>
					<% }) %>
				</div>
			</div>
		</section>
	</main>

	<script>
		const sidebarToggle = document.getElementById('sidebar-toggle');
		const sidebar = document.getElementById('app-sidebar');
		const overlay = document.getElementById('app-overlay');

		if (sidebarToggle && sidebar && overlay) {
			sidebarToggle.addEventListener('click', () => {
				sidebar.classList.toggle('show');
				overlay.classList.toggle('show');
			});

			overlay.addEventListener('click', () => {
				sidebar.classList.remove('show');
				overlay.classList.remove('show');
			});
		}

		const donutCtx = document.getElementById('expenseDonutChart');
		if (donutCtx) {
			const expensePalette = [
				'#dc2626', // red-600
				'#ef4444', // red-500
				'#f97316', // orange-500
				'#f59e0b', // amber-500
				'#e11d48', // rose-600
				'#be123c', // rose-700
				'#7f1d1d'  // red-900
			];

			new Chart(donutCtx, {
				type: 'doughnut',
				data: {
					labels: <%- JSON.stringify(donutLabels) %>,
					datasets: [{
						data: <%- JSON.stringify(donutValues) %>,
						backgroundColor: expensePalette,
						borderColor: '#ffffff',
						borderWidth: 2
					}]
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					cutout: '65%',
					plugins: {
						legend: {
							position: 'bottom'
						}
					}
				}
			});
		}

		const barCtx = document.getElementById('incomeExpenseBarChart');
		if (barCtx) {
			new Chart(barCtx, {
				type: 'bar',
				data: {
					labels: <%- JSON.stringify(trendLabels) %>,
					datasets: [
						{
							label: 'Income',
							data: <%- JSON.stringify(trendIncomeValues) %>,
							backgroundColor: 'rgba(37, 99, 235, 0.85)',
							borderColor: 'rgba(37, 99, 235, 1)',
							borderWidth: 1,
							borderRadius: 8
						},
						{
							label: 'Expense',
							data: <%- JSON.stringify(trendExpenseValues) %>,
							backgroundColor: 'rgba(220, 38, 38, 0.85)',
							borderColor: 'rgba(220, 38, 38, 1)',
							borderWidth: 1,
							borderRadius: 8
