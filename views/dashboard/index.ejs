<!DOCTYPE html>
<html lang="en">

<head>
	<%- include('../partials/app_head') %>
	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="min-h-screen bg-stone-50 text-stone-800">
	<%- include('../partials/sidebar') %>

	<div id="app-overlay" class="app-overlay lg:hidden"></div>

	<main class="app-main px-4 py-4 sm:px-6 sm:py-6">
		<%- include('../partials/topbar') %>

		<%
			const safeFilters = filters || { from_date: '', to_date: '', trend_granularity: 'month' };

			const safeSummary = summary || {
				total_income: 0,
				total_expense: 0,
				total_transfer: 0,
				balance: 0,
				transaction_count: 0,
				transaction_included_count: 0,
				transaction_excluded_count: 0
			};

			const safeRecentTransactions = Array.isArray(recent_transactions) ? recent_transactions : [];
			const safeTopCategories = Array.isArray(top_categories) ? top_categories : [];
			const safeIncomeExpenseTrend = Array.isArray(income_expense_trend) ? income_expense_trend : [];
			const safeTrendGranularity = typeof trend_granularity === 'string' ? trend_granularity : 'month';
			const safeExpenseByCategory = Array.isArray(expense_by_category) ? expense_by_category : [];
			const safeWeeklyCheckin = weekly_checkin || {
				current_week: {
					from_date: '',
					to_date: '',
					total_income: 0,
					total_expense: 0,
					transaction_count: 0,
					balance: 0
				},
				previous_week: {
					from_date: '',
					to_date: '',
					total_income: 0,
					total_expense: 0,
					transaction_count: 0,
					balance: 0
				},
				expense_delta: 0,
				recommendation: {
					title: 'Keep your weekly check-in',
					message: 'Weekly insights will appear once transactions are available.',
					cta_label: 'Open transactions',
					cta_href: '/transaction'
				}
			};
			const safeActionableInsights = Array.isArray(actionable_insights) ? actionable_insights : [];
			const safeBudgetAlerts = budget_alerts || { near_count: 0, over_count: 0, tracked_count: 0 };
			const safePlanVsActual = plan_vs_actual && typeof plan_vs_actual === 'object' ? plan_vs_actual : {
				plan_month: '',
				plan_month_label: '',
				range_spans_multiple_months: false,
				planned_income: 0,
				planned_expense_total: 0,
				actual_income: 0,
				actual_expense: 0,
				net_planned: 0,
				net_actual: 0,
				variance_income: 0,
				variance_expense: 0,
				variance_net: 0,
				expense_pct_of_planned: null
			};

			function formatCurrency(value) {
				return 'Rp ' + Number(value || 0).toLocaleString('id-ID');
			}

			function getTypeBadgeClass(type) {
				if (type === 'income') return 'bg-emerald-100 text-emerald-700';
				if (type === 'expense') return 'bg-rose-100 text-rose-700';
				return 'bg-amber-100 text-amber-700';
			}

			function getAmountClass(type) {
				if (type === 'income') return 'text-emerald-700';
				if (type === 'expense') return 'text-rose-700';
				return 'text-stone-800';
			}

			function getAmountPrefix(type) {
				if (type === 'income') return '+ ';
				if (type === 'expense') return '- ';
				return '';
			}

			const highestCategoryTotal = safeTopCategories.length > 0
				? Number(safeTopCategories[0].total || 0)
				: 0;

			const donutLabels = safeExpenseByCategory.map((item) => item.category_name);
			const donutValues = safeExpenseByCategory.map((item) => Number(item.total || 0));

			const trendLabels = safeIncomeExpenseTrend.map((item) => item.period_label);
			const trendIncomeValues = safeIncomeExpenseTrend.map((item) => Number(item.total_income || 0));
			const trendExpenseValues = safeIncomeExpenseTrend.map((item) => Number(item.total_expense || 0));

			let trendSubtitle = 'Grouped by month for the selected date range.';
			if (safeTrendGranularity === 'day') {
				trendSubtitle = 'Grouped by day for the selected date range.';
			}
			if (safeTrendGranularity === 'year') {
				trendSubtitle = 'Grouped by year for the selected date range.';
			}
		%>

		<% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
		<div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">
			<%= success_msg[0] %>
		</div>
		<% } %>

		<% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
		<div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-800">
			<%= error_msg[0] %>
		</div>
		<% } %>

		<% if (safeBudgetAlerts.over_count > 0 || safeBudgetAlerts.near_count > 0) { %>
		<div class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950">
			<p class="font-semibold text-amber-900">Budget reminder</p>
			<p class="mt-1 leading-relaxed text-amber-900/90">
				<% if (safeBudgetAlerts.over_count > 0) { %>
					<span class="font-medium text-rose-700"><%= safeBudgetAlerts.over_count %> over limit</span>
				<% } %>
				<% if (safeBudgetAlerts.over_count > 0 && safeBudgetAlerts.near_count > 0) { %> · <% } %>
				<% if (safeBudgetAlerts.near_count > 0) { %>
					<span class="font-medium text-amber-800"><%= safeBudgetAlerts.near_count %> at ≥80% of limit</span>
				<% } %>
				<span class="text-amber-800/90"> (active budgets covering today).</span>
				<a href="/budget" class="ml-1 font-semibold text-pine underline decoration-pine/40 underline-offset-2">Review budgets</a>
			</p>
		</div>
		<% } %>

		<section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
			<div class="relative overflow-hidden border-b border-stone-100 bg-gradient-to-r from-emerald-50 via-white to-amber-50 px-5 py-6 sm:px-7 sm:py-7">
				<div class="absolute inset-y-0 right-0 hidden w-1/3 bg-[radial-gradient(circle_at_center,rgba(16,185,129,0.10),transparent_60%)] lg:block"></div>

				<div class="relative flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
					<div class="max-w-2xl">
						<div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 shadow-sm">
							Dashboard
						</div>

						<h1 class="mt-4 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">
							Welcome back to your money overview
						</h1>

						<p class="mt-2 text-sm leading-7 text-stone-600">
							Your summary for
							<span class="font-semibold text-stone-800"><%= safeFilters.from_date %></span>
							through
							<span class="font-semibold text-stone-800"><%= safeFilters.to_date %></span>.
						</p>
						<p class="mt-3 text-sm text-stone-600">
							<a href="#dashboard-filters" class="font-semibold text-emerald-700 underline decoration-emerald-700/30 underline-offset-2 hover:text-emerald-800">Change period &amp; chart</a>
							<span class="text-stone-500"> — use the form below, above the summary figures.</span>
						</p>
					</div>

					<!-- <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 xl:w-[360px]">
						<div class="rounded-2xl border border-stone-200 bg-white/90 px-4 py-3 shadow-sm">
							<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Income</p>
							<p class="mt-1 text-sm font-semibold text-emerald-700"><%= formatCurrency(safeSummary.total_income) %></p>
						</div>

						<div class="rounded-2xl border border-stone-200 bg-white/90 px-4 py-3 shadow-sm">
							<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Expense</p>
							<p class="mt-1 text-sm font-semibold text-rose-700"><%= formatCurrency(safeSummary.total_expense) %></p>
						</div>

						<div class="col-span-2 rounded-2xl border border-stone-200 bg-white/90 px-4 py-3 shadow-sm sm:col-span-1">
							<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Balance</p>
							<p class="mt-1 text-sm font-semibold text-stone-900"><%= formatCurrency(safeSummary.balance) %></p>
						</div>
					</div> -->
				</div>
			</div>

			<div class="px-5 py-5 sm:px-7 sm:py-6">
				<div id="dashboard-filters" class="scroll-mt-24 rounded-[28px] border-2 border-emerald-200/80 bg-emerald-50/40 p-4 shadow-sm sm:p-5">
					<p class="text-base font-semibold text-stone-900">Period filter</p>
					<p class="mt-1 text-sm text-stone-600">Pick dates then click <span class="font-medium text-stone-800">Apply filter</span> to refresh this page.</p>
					<form method="GET" action="/dashboard" class="mt-4">
						<div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-[1fr_1fr_1fr_auto_auto] xl:items-end">
							<div class="min-w-0">
								<label class="mb-2 block text-sm font-semibold text-stone-800">From date</label>
								<input
									type="date"
									name="from_date"
									value="<%= safeFilters.from_date %>"
									class="w-full min-w-0 rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100"
									required
								>
							</div>

							<div class="min-w-0">
								<label class="mb-2 block text-sm font-semibold text-stone-800">To date</label>
								<input
									type="date"
									name="to_date"
									value="<%= safeFilters.to_date %>"
									class="w-full min-w-0 rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100"
									required
								>
							</div>

							<div class="min-w-0">
								<label class="mb-2 block text-sm font-semibold text-stone-800">Trend chart</label>
								<select
									name="trend_granularity"
									class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100"
								>
									<option value="day" <%= safeTrendGranularity === 'day' ? 'selected' : '' %>>By day</option>
									<option value="month" <%= safeTrendGranularity === 'month' ? 'selected' : '' %>>By month</option>
									<option value="year" <%= safeTrendGranularity === 'year' ? 'selected' : '' %>>By year</option>
								</select>
							</div>

							<div class="flex md:col-span-2 xl:col-span-1">
								<a
									href="/dashboard"
									class="inline-flex h-[50px] w-full items-center justify-center rounded-2xl border border-stone-200 bg-white px-5 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-stone-300"
								>
									Reset period
								</a>
							</div>

							<div class="flex md:col-span-2 xl:col-span-1">
								<button
									type="submit"
									class="inline-flex h-[50px] w-full min-w-[140px] items-center justify-center rounded-2xl bg-emerald-600 px-5 text-sm font-semibold text-white shadow-lg shadow-emerald-600/25 transition hover:-translate-y-0.5 hover:bg-emerald-700"
								>
									Apply filter
								</button>
							</div>
						</div>
					</form>
				</div>

				<div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
					<div class="rounded-[28px] border border-stone-200/80 bg-white p-5 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-medium text-stone-500">Total Income</p>
								<h3 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight text-stone-900 whitespace-nowrap">
									<%= formatCurrency(safeSummary.total_income) %>
								</h3>
								<p class="mt-2 text-xs text-emerald-600">For <%= safeFilters.from_date %> until <%= safeFilters.to_date %></p>
							</div>
							<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-lg font-semibold text-emerald-700">↗</div>
						</div>
					</div>

					<div class="rounded-[28px] border border-stone-200/80 bg-white p-5 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-medium text-stone-500">Total Expense</p>
								<h3 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight text-stone-900 whitespace-nowrap">
									<%= formatCurrency(safeSummary.total_expense) %>
								</h3>
								<p class="mt-2 text-xs text-rose-600">For <%= safeFilters.from_date %> until <%= safeFilters.to_date %></p>
							</div>
							<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-rose-100 text-lg font-semibold text-rose-700">↘</div>
						</div>
					</div>

					<div class="rounded-[28px] border border-stone-200/80 bg-white p-5 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-medium text-stone-500">Current Balance</p>
								<h3 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight text-stone-900 whitespace-nowrap">
									<%= formatCurrency(safeSummary.balance) %>
								</h3>
								<p class="mt-2 text-xs text-amber-700">Income minus expense</p>
							</div>
							<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-100 text-lg font-semibold text-amber-700">◎</div>
						</div>
					</div>

					<div class="rounded-[28px] border border-stone-200/80 bg-white p-5 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-medium text-stone-500">Transactions</p>
								<h3 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight text-stone-900 whitespace-nowrap"><%= safeSummary.transaction_count %></h3>
								<div class="mt-2 space-y-1 text-[11px] leading-4">
									<div class="flex items-center gap-2 text-stone-500">
										<span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
										<span>Included</span>
										<span class="font-semibold text-emerald-700"><%= safeSummary.transaction_included_count %></span>
									</div>
									<div class="flex items-center gap-2 text-stone-500">
										<span class="inline-block h-1.5 w-1.5 rounded-full bg-amber-500"></span>
										<span>Excluded</span>
										<span class="font-semibold text-amber-700"><%= safeSummary.transaction_excluded_count %></span>
									</div>
								</div>
							</div>
							<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-stone-200 text-lg font-semibold text-stone-700">▣</div>
						</div>
					</div>
				</div>

				<% if (safePlanVsActual.plan_month) { %>
				<div class="mt-6 overflow-hidden rounded-[28px] border border-teal-200/80 bg-gradient-to-br from-teal-50/90 via-white to-stone-50/80 p-5 shadow-sm sm:p-6">
					<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
						<div>
							<p class="text-base font-semibold text-stone-900">Plan vs actual (period)</p>
							<p class="mt-1 text-sm text-stone-600">
								Expense plan = sum of active <span class="font-medium text-stone-800">expense</span> budget limits overlapping
								<span class="font-medium text-stone-800"><%= safeFilters.from_date %></span>–<span class="font-medium text-stone-800"><%= safeFilters.to_date %></span>.
								Income target is for <span class="font-medium text-stone-800"><%= safePlanVsActual.plan_month_label %></span>.
							</p>
							<% if (safePlanVsActual.range_spans_multiple_months) { %>
							<p class="mt-2 text-xs text-amber-800">
								Period spans multiple months — the income target still applies only to <span class="font-semibold"><%= safePlanVsActual.plan_month_label %></span> (month of the start date).
							</p>
							<% } %>
						</div>
						<a href="/budget/recap?from_date=<%= encodeURIComponent(safeFilters.from_date) %>&to_date=<%= encodeURIComponent(safeFilters.to_date) %>" class="shrink-0 text-sm font-semibold text-teal-800 underline decoration-teal-600/40 underline-offset-2 hover:text-teal-950">Open recap</a>
					</div>

					<div class="mt-5 overflow-x-auto rounded-2xl border border-stone-200/80 bg-white/90">
						<table class="min-w-[520px] w-full border-collapse text-sm">
							<thead>
								<tr class="border-b border-stone-200 bg-stone-50/90 text-left text-xs font-semibold uppercase tracking-[0.12em] text-stone-500">
									<th class="px-4 py-3"></th>
									<th class="px-4 py-3 text-right">Planned</th>
									<th class="px-4 py-3 text-right">Actual</th>
									<th class="px-4 py-3 text-right">Variance</th>
								</tr>
							</thead>
							<tbody class="text-stone-800">
								<tr class="border-b border-stone-100">
									<td class="px-4 py-3 font-medium">Income</td>
									<td class="px-4 py-3 text-right tabular-nums text-emerald-800"><%= formatCurrency(safePlanVsActual.planned_income) %></td>
									<td class="px-4 py-3 text-right tabular-nums font-semibold text-emerald-700"><%= formatCurrency(safePlanVsActual.actual_income) %></td>
									<td class="px-4 py-3 text-right tabular-nums <%= Number(safePlanVsActual.variance_income || 0) >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
										<%= Number(safePlanVsActual.variance_income || 0) >= 0 ? '+' : '' %><%= formatCurrency(safePlanVsActual.variance_income) %>
									</td>
								</tr>
								<tr class="border-b border-stone-100">
									<td class="px-4 py-3 font-medium">Expense</td>
									<td class="px-4 py-3 text-right tabular-nums text-rose-800/90"><%= formatCurrency(safePlanVsActual.planned_expense_total) %></td>
									<td class="px-4 py-3 text-right tabular-nums font-semibold text-rose-700"><%= formatCurrency(safePlanVsActual.actual_expense) %></td>
									<td class="px-4 py-3 text-right tabular-nums <%= Number(safePlanVsActual.variance_expense || 0) <= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
										<%= Number(safePlanVsActual.variance_expense || 0) > 0 ? '+' : '' %><%= formatCurrency(safePlanVsActual.variance_expense) %>
									</td>
								</tr>
								<tr>
									<td class="px-4 py-3 font-semibold text-stone-900">Net (income − expense)</td>
									<td class="px-4 py-3 text-right tabular-nums font-medium text-stone-800"><%= formatCurrency(safePlanVsActual.net_planned) %></td>
									<td class="px-4 py-3 text-right tabular-nums font-bold text-stone-900"><%= formatCurrency(safePlanVsActual.net_actual) %></td>
									<td class="px-4 py-3 text-right tabular-nums font-semibold <%= Number(safePlanVsActual.variance_net || 0) >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
										<%= Number(safePlanVsActual.variance_net || 0) >= 0 ? '+' : '' %><%= formatCurrency(safePlanVsActual.variance_net) %>
									</td>
								</tr>
							</tbody>
						</table>
					</div>

					<% if (safePlanVsActual.planned_expense_total > 0 && safePlanVsActual.expense_pct_of_planned !== null) { %>
					<div class="mt-4">
						<div class="flex items-center justify-between text-xs font-medium text-stone-600">
							<span>Actual expense vs planned budgets (sum)</span>
							<span class="tabular-nums text-stone-800"><%= safePlanVsActual.expense_pct_of_planned %>%</span>
						</div>
						<div class="mt-2 h-2.5 overflow-hidden rounded-full bg-stone-200">
							<div
								class="h-full rounded-full bg-gradient-to-r from-teal-500 to-emerald-500 transition-all"
								style="width: <%= Math.min(100, Number(safePlanVsActual.expense_pct_of_planned || 0)) %>%"
							></div>
						</div>
					</div>
					<% } %>

					<form method="POST" action="/dashboard/planned-income" class="mt-5 flex flex-col gap-3 rounded-2xl border border-stone-200 bg-white/95 p-4 sm:flex-row sm:flex-wrap sm:items-end">
						<div class="min-w-[200px] flex-1">
							<label for="planned_income_input" class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.1em] text-stone-500">Planned income (<%= safePlanVsActual.plan_month_label %>)</label>
							<input
								type="number"
								name="planned_income"
								id="planned_income_input"
								min="0"
								step="0.01"
								value="<%= safePlanVsActual.planned_income %>"
								class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-teal-500 focus:ring-4 focus:ring-teal-100"
								placeholder="0"
							>
						</div>
						<input type="hidden" name="plan_month" value="<%= safePlanVsActual.plan_month %>">
						<input type="hidden" name="redirect_from_date" value="<%= safeFilters.from_date %>">
						<input type="hidden" name="redirect_to_date" value="<%= safeFilters.to_date %>">
						<input type="hidden" name="redirect_trend_granularity" value="<%= safeTrendGranularity %>">
						<button type="submit" class="inline-flex h-[50px] items-center justify-center rounded-2xl bg-teal-700 px-6 text-sm font-semibold text-white shadow-md shadow-teal-700/20 transition hover:-translate-y-0.5 hover:bg-teal-800">
							Save income target
						</button>
					</form>
					<p class="mt-3 text-xs text-stone-500">Transfers are excluded from income and expense totals. Set your expected take-home (or similar) for the calendar month above.</p>
				</div>
				<% } %>
			</div>
		</section>

		<section class="mt-6 grid grid-cols-1 gap-6 2xl:grid-cols-3">
			<div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/50 sm:p-6">
				<div>
					<p class="text-base font-semibold text-stone-900">Expense Composition</p>
					<p class="mt-1 text-sm text-stone-500">Expense by category for current month</p>
				</div>

				<div class="mt-6 h-[320px] rounded-[24px] border border-stone-200 bg-stone-50 p-4">
					<canvas id="expenseDonutChart"></canvas>
				</div>
			</div>

			<div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/50 sm:p-6 2xl:col-span-2">
				<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
					<div>
						<p class="text-base font-semibold text-stone-900">Income vs Expense Trend</p>
						<p class="mt-1 text-sm text-stone-500"><%= trendSubtitle %></p>
						<p class="mt-2">
							<a href="#dashboard-filters" class="text-sm font-semibold text-emerald-700 underline decoration-emerald-700/30 underline-offset-2 hover:text-emerald-800">Change period (dates) in the filter above</a>
						</p>
					</div>
					<div class="min-w-[200px]">
						<label for="trend-granularity-quick" class="mb-1 block text-xs font-semibold uppercase tracking-[0.12em] text-stone-500">Group by</label>
						<select
							id="trend-granularity-quick"
							class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-2.5 text-sm font-medium text-stone-800 outline-none focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100"
						>
							<option value="day" <%= safeTrendGranularity === 'day' ? 'selected' : '' %>>By day</option>
							<option value="month" <%= safeTrendGranularity === 'month' ? 'selected' : '' %>>By month</option>
							<option value="year" <%= safeTrendGranularity === 'year' ? 'selected' : '' %>>By year</option>
						</select>
					</div>
				</div>

				<div class="mt-6 h-[320px] rounded-[24px] border border-stone-200 bg-stone-50 p-4">
					<canvas id="incomeExpenseBarChart"></canvas>
				</div>
			</div>
		</section>

		<section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
			<div class="border-b border-stone-100 bg-gradient-to-r from-indigo-50 via-white to-rose-50 px-5 py-5 sm:px-7 sm:py-6">
				<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
					<div>
						<p class="text-base font-semibold text-stone-900">Weekly Check-In</p>
						<p class="mt-1 text-sm text-stone-500">
							<%= safeWeeklyCheckin.current_week.from_date %> - <%= safeWeeklyCheckin.current_week.to_date %>
						</p>
					</div>
					<a
						href="/transaction?from_date=<%= encodeURIComponent(safeWeeklyCheckin.current_week.from_date || '') %>&to_date=<%= encodeURIComponent(safeWeeklyCheckin.current_week.to_date || '') %>"
						class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-4 py-2 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-stone-300"
					>
						Open week details
					</a>
				</div>
			</div>

			<div class="px-5 py-6 sm:px-7 sm:py-7">
				<div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
					<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
						<p class="text-xs uppercase tracking-[0.14em] text-stone-500">This Week Income</p>
						<p class="mt-2 text-base font-bold text-blue-700 whitespace-nowrap"><%= formatCurrency(safeWeeklyCheckin.current_week.total_income) %></p>
					</div>
					<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
						<p class="text-xs uppercase tracking-[0.14em] text-stone-500">This Week Expense</p>
						<p class="mt-2 text-base font-bold text-rose-700 whitespace-nowrap"><%= formatCurrency(safeWeeklyCheckin.current_week.total_expense) %></p>
					</div>
					<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
						<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Weekly Balance</p>
						<p class="mt-2 text-base font-bold text-stone-900 whitespace-nowrap"><%= formatCurrency(safeWeeklyCheckin.current_week.balance) %></p>
					</div>
					<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
						<p class="text-xs uppercase tracking-[0.14em] text-stone-500">Expense vs Last Week</p>
						<p class="mt-2 text-base font-bold <%= Number(safeWeeklyCheckin.expense_delta || 0) > 0 ? 'text-rose-700' : 'text-emerald-700' %> whitespace-nowrap">
							<%= Number(safeWeeklyCheckin.expense_delta || 0) > 0 ? '+' : '' %><%= formatCurrency(safeWeeklyCheckin.expense_delta) %>
						</p>
					</div>
				</div>

				<div class="mt-5 rounded-[28px] border border-indigo-100 bg-gradient-to-r from-indigo-50/70 to-rose-50/70 p-5">
					<p class="text-sm font-semibold text-stone-900"><%= safeWeeklyCheckin.recommendation.title %></p>
					<p class="mt-2 text-sm leading-7 text-stone-600"><%= safeWeeklyCheckin.recommendation.message %></p>
					<a
						href="<%= safeWeeklyCheckin.recommendation.cta_href %>"
						class="mt-4 inline-flex items-center justify-center rounded-2xl bg-stone-900 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-emerald-700"
					>
						<%= safeWeeklyCheckin.recommendation.cta_label %>
					</a>
				</div>
			</div>
		</section>

		<section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
			<div class="border-b border-stone-100 bg-gradient-to-r from-violet-50 via-white to-sky-50 px-5 py-5 sm:px-7 sm:py-6">
				<p class="text-base font-semibold text-stone-900">Actionable Insights</p>
				<p class="mt-1 text-sm text-stone-500">Small next steps based on your latest financial pattern.</p>
			</div>

			<div class="px-5 py-6 sm:px-7 sm:py-7">
				<div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
					<% if (safeActionableInsights.length === 0) { %>
					<div class="xl:col-span-3 rounded-[24px] border border-stone-200 bg-stone-50 p-4 text-sm text-stone-500">
						No insights yet. Add more transactions to unlock personalized recommendations.
					</div>
					<% } %>

					<% safeActionableInsights.forEach((insight) => { %>
					<div class="rounded-[24px] border border-stone-200 bg-white p-4 shadow-sm">
						<p class="text-sm font-semibold text-stone-900"><%= insight.title %></p>
						<p class="mt-2 text-sm leading-7 text-stone-600"><%= insight.message %></p>
						<a
							href="<%= insight.cta_href %>"
							class="mt-4 inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-stone-50 px-4 py-2 text-sm font-semibold text-stone-700 transition hover:-translate-y-0.5 hover:border-stone-300"
						>
							<%= insight.cta_label %>
						</a>
					</div>
					<% }) %>
				</div>
			</div>
		</section>

		<section class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-3">
			<div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50 xl:col-span-2">
				<div class="flex items-center justify-between gap-4 border-b border-stone-100 px-5 py-5 sm:px-7 sm:py-6">
					<div>
						<p class="text-base font-semibold text-stone-900">Recent Transactions</p>
						<p class="mt-1 text-sm text-stone-500">Latest money movements from your database</p>
					</div>

					<a href="/transaction" class="text-sm font-semibold text-emerald-700 hover:underline">
						View all
					</a>
				</div>

				<div class="px-5 py-6 sm:px-7 sm:py-7">
					<div class="space-y-4">
						<% if (safeRecentTransactions.length === 0) { %>
						<div class="rounded-[24px] border border-stone-200 bg-stone-50 p-4 text-sm text-stone-500">
							No transactions found yet. Start by creating your first transaction.
						</div>
						<% } %>

						<% safeRecentTransactions.forEach((item) => { %>
						<div class="flex flex-col gap-3 rounded-[28px] border border-stone-200 bg-white p-4 shadow-sm sm:flex-row sm:items-center sm:justify-between">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl text-base font-bold <%= getTypeBadgeClass(item.transaction_type) %>">
									<%= item.transaction_type === 'income' ? '↗' : item.transaction_type === 'expense' ? '↘' : '◎' %>
								</div>
								<div>
									<p class="font-semibold text-stone-900"><%= item.description || item.category_name || 'No description' %></p>
									<p class="text-sm text-stone-500">
										<%= item.category_name || '-' %> • <%= formatDateWib(item.transaction_date) %> • <%= item.account_name || '-' %>
									</p>
								</div>
							</div>
							<div class="sm:text-right">
								<p class="text-sm font-semibold <%= getAmountClass(item.transaction_type) %> whitespace-nowrap">
									<%= getAmountPrefix(item.transaction_type) %><%= formatCurrency(item.amount) %>
								</p>
							</div>
						</div>
						<% }) %>
					</div>
				</div>
			</div>

			<div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/50 sm:p-6">
				<div>
					<p class="text-base font-semibold text-stone-900">Top Categories</p>
					<p class="mt-1 text-sm text-stone-500">Highest expense categories this month</p>
				</div>

				<div class="mt-6 space-y-5">
					<% if (safeTopCategories.length === 0) { %>
					<div class="rounded-[24px] border border-stone-200 bg-stone-50 p-4 text-sm text-stone-500">
						No expense category data available yet.
					</div>
					<% } %>

					<% safeTopCategories.forEach((item) => { %>
					<%
                        const itemTotal = Number(item.total || 0);
                        const percentage = highestCategoryTotal > 0
                            ? Math.max((itemTotal / highestCategoryTotal) * 100, 6)
                            : 0;
                    %>

					<div>
						<div class="mb-2 flex items-center justify-between gap-4">
							<p class="text-sm font-semibold text-stone-900"><%= item.category_name %></p>
							<p class="text-sm text-stone-500 whitespace-nowrap"><%= formatCurrency(item.total) %></p>
						</div>
						<div class="h-2.5 overflow-hidden rounded-full bg-stone-100">
							<span class="block h-full rounded-full bg-gradient-to-r from-emerald-400 to-emerald-600" style="width: <%= percentage %>%;"></span>
						</div>
					</div>
					<% }) %>
				</div>
			</div>
		</section>
	</main>

	<script>
		const sidebarToggle = document.getElementById('sidebar-toggle');
		const sidebar = document.getElementById('app-sidebar');
		const overlay = document.getElementById('app-overlay');

		if (sidebarToggle && sidebar && overlay) {
			sidebarToggle.addEventListener('click', () => {
				sidebar.classList.toggle('show');
				overlay.classList.toggle('show');
			});

			overlay.addEventListener('click', () => {
				sidebar.classList.remove('show');
				overlay.classList.remove('show');
			});
		}

		const donutCtx = document.getElementById('expenseDonutChart');
		if (donutCtx) {
			const expensePalette = [
				'#dc2626', // red-600
				'#ef4444', // red-500
				'#f97316', // orange-500
				'#f59e0b', // amber-500
				'#e11d48', // rose-600
				'#be123c', // rose-700
				'#7f1d1d'  // red-900
			];

			new Chart(donutCtx, {
				type: 'doughnut',
				data: {
					labels: <%- JSON.stringify(donutLabels) %>,
					datasets: [{
						data: <%- JSON.stringify(donutValues) %>,
						backgroundColor: expensePalette,
						borderColor: '#ffffff',
						borderWidth: 2
					}]
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					cutout: '65%',
					plugins: {
						legend: {
							position: 'bottom'
						}
					}
				}
			});
		}

		const barCtx = document.getElementById('incomeExpenseBarChart');
		if (barCtx) {
			new Chart(barCtx, {
				type: 'bar',
				data: {
					labels: <%- JSON.stringify(trendLabels) %>,
					datasets: [
						{
							label: 'Income',
							data: <%- JSON.stringify(trendIncomeValues) %>,
							backgroundColor: 'rgba(37, 99, 235, 0.85)',
							borderColor: 'rgba(37, 99, 235, 1)',
							borderWidth: 1,
							borderRadius: 8
						},
						{
							label: 'Expense',
							data: <%- JSON.stringify(trendExpenseValues) %>,
							backgroundColor: 'rgba(220, 38, 38, 0.85)',
							borderColor: 'rgba(220, 38, 38, 1)',
							borderWidth: 1,
							borderRadius: 8
						}
					]
				},
				options: {
					responsive: true,
					maintainAspectRatio: false
				}
			});
		}

		const trendQuick = document.getElementById('trend-granularity-quick');
		if (trendQuick) {
			trendQuick.addEventListener('change', () => {
				const nextUrl = new URL(window.location.href);
				nextUrl.searchParams.set('trend_granularity', trendQuick.value);
				window.location.assign(nextUrl.toString());
			});
		}
	</script>
</body>

</html>