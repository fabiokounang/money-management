<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/app_head') %>
</head>
<body class="min-h-screen bg-stone-50 text-stone-800">
  <%- include('../partials/sidebar') %>
  <div id="app-overlay" class="app-overlay lg:hidden"></div>

  <main class="app-main px-4 py-4 sm:px-6 sm:py-6">
    <%- include('../partials/topbar') %>

    <section class="mt-6 max-w-3xl">
      <div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl">
        <div class="border-b border-stone-100 bg-gradient-to-r from-emerald-50 to-amber-50 px-5 py-5 sm:px-7">
          <h1 class="text-2xl font-bold text-stone-900">Import transactions from CSV</h1>
          <p class="mt-2 text-sm text-stone-600">Map columns by <strong>0-based index</strong> (first column = 0). Dates: <code class="rounded bg-stone-100 px-1">YYYY-MM-DD</code> or <code class="rounded bg-stone-100 px-1">DD/MM/YYYY</code>. Amounts may use commas.</p>
          <a href="/transaction" class="mt-4 inline-block text-sm font-semibold text-emerald-700 hover:underline">← Back to transactions</a>
        </div>

        <div class="px-5 py-6 sm:px-7">
          <% if (typeof error !== 'undefined' && error) { %>
          <div class="mb-5 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
          <% } %>

          <% if (typeof result !== 'undefined' && result) { %>
          <div class="mb-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
            Imported <strong><%= result.imported %></strong> row(s).
            <% if (result.failures && result.failures.length > 0) { %>
            <p class="mt-2 font-semibold text-amber-900"><%= result.failures.length %> row(s) skipped:</p>
            <ul class="mt-2 max-h-48 list-disc space-y-1 overflow-y-auto pl-5 text-xs text-stone-700">
              <% result.failures.slice(0, 40).forEach((f) => { %>
              <li>Line <%= f.row %>: <%= f.reason %></li>
              <% }) %>
              <% if (result.failures.length > 40) { %>
              <li>…and more</li>
              <% } %>
            </ul>
            <% } %>
          </div>
          <% } %>

          <form action="/transaction/import" method="POST" enctype="multipart/form-data" class="space-y-6">
            <div>
              <label class="mb-2 block text-sm font-semibold text-stone-800">CSV file *</label>
              <input type="file" name="csv_file" accept=".csv,text/csv" required class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm file:mr-4 file:rounded-xl file:border-0 file:bg-emerald-100 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-emerald-800">
            </div>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-2 block text-sm font-semibold text-stone-800">Date column index *</label>
                <input type="number" name="col_date" min="0" value="0" required class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-stone-800">Amount column index *</label>
                <input type="number" name="col_amount" min="0" value="1" required class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-stone-800">Description column (optional)</label>
                <input type="number" name="col_desc" min="0" placeholder="leave blank if none" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-stone-800">Type column (optional)</label>
                <input type="number" name="col_type" min="0" placeholder="income / expense" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
              </div>
            </div>

            <label class="flex cursor-pointer items-center gap-2 text-sm text-stone-800">
              <input type="checkbox" name="has_header" value="1" checked class="h-4 w-4 rounded border-stone-300 text-emerald-600">
              First row is header (skip it)
            </label>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-2 block text-sm font-semibold text-stone-800">Default type (if no type column)</label>
                <select name="default_transaction_type" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
                  <option value="expense">Expense</option>
                  <option value="income">Income</option>
                </select>
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-stone-800">Payment method</label>
                <select name="payment_method" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
                  <option value="bank_transfer">Bank transfer</option>
                  <option value="cash">Cash</option>
                  <option value="debit_card">Debit</option>
                  <option value="credit_card">Credit</option>
                  <option value="qris">QRIS</option>
                  <option value="ewallet">E-wallet</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-stone-800">Post into account *</label>
                <select name="account_id" required class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
                  <option value="">Select</option>
                  <% (accounts || []).forEach((a) => { %>
                  <option value="<%= a.id %>"><%= a.account_name %> (<%= a.account_type %>)</option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-stone-800">Default category (optional)</label>
                <select name="category_id" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
                  <option value="">—</option>
                  <% (filter_categories || []).forEach((c) => { %>
                  <option value="<%= c.id %>"><%= c.category_name %> (<%= c.category_type %>)</option>
                  <% }) %>
                </select>
              </div>
            </div>

            <p class="text-xs text-stone-500"><strong>Note:</strong> This importer supports only income and expense rows (single-account lines). Use type column + default account for simple bank exports.</p>

            <button type="submit" class="w-full rounded-2xl bg-stone-900 py-3 text-sm font-semibold text-white hover:bg-emerald-700 sm:w-auto sm:px-8">Upload & import</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <script>
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('app-sidebar');
    const overlay = document.getElementById('app-overlay');
    if (sidebarToggle && sidebar && overlay) {
      sidebarToggle.addEventListener('click', () => { sidebar.classList.toggle('show'); overlay.classList.toggle('show'); });
      overlay.addEventListener('click', () => { sidebar.classList.remove('show'); overlay.classList.remove('show'); });
    }
  </script>
</body>
</html>
