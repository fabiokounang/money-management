<!DOCTYPE html>
<html lang="en">

<head>
	<%- include('../partials/app_head') %>
</head>

<body class="min-h-screen bg-stone-50 text-stone-800">
	<%- include('../partials/sidebar') %>

	<div id="app-overlay" class="app-overlay lg:hidden"></div>

	<main class="app-main px-4 py-4 sm:px-6 sm:py-6">
		<%- include('../partials/topbar') %>

		<%
            const safeTransactions = Array.isArray(transactions) ? transactions : [];
            const currentPage = Number(page || 1);
            const perPage = Number(limit || 10);
            const totalRows = Number(total || 0);
            const totalPages = Number(total_pages || 1);
            const safeFilters = filters || {
                from_date: '',
                to_date: ''
            };

            let totalIncome = 0;
            let totalExpense = 0;
            let totalTransfer = 0;

            safeTransactions.forEach((item) => {
                const amount = Number(item.amount || 0);

                if (item.transaction_type === 'income') {
                    totalIncome += amount;
                }

                if (item.transaction_type === 'expense') {
                    totalExpense += amount;
                }

                if (item.transaction_type === 'transfer') {
                    totalTransfer += amount;
                }
            });

            const startRow = totalRows === 0 ? 0 : ((currentPage - 1) * perPage) + 1;
            const endRow = Math.min(currentPage * perPage, totalRows);

            function formatCurrency(value) {
                return 'Rp ' + Number(value || 0).toLocaleString('id-ID');
            }

            function getTypeBadgeClass(type) {
                if (type === 'income') return 'bg-emerald-100 text-emerald-700';
                if (type === 'expense') return 'bg-rose-100 text-rose-700';
                return 'bg-amber-100 text-amber-700';
            }

            function getTypeLabel(type) {
                if (type === 'income') return 'Income';
                if (type === 'expense') return 'Expense';
                if (type === 'transfer') return 'Transfer';
                return '-';
            }

            function getDisplayDescription(item) {
                return item.description || item.category_name || 'No description';
            }

            function getDisplayCategory(item) {
                if (item.transaction_type === 'transfer') {
                    return '-';
                }

                if (item.subcategory_name) {
                    return `${item.category_name || '-'} / ${item.subcategory_name}`;
                }

                return item.category_name || '-';
            }

            function getDisplayAccount(item) {
                if (item.transaction_type === 'transfer') {
                    const fromName = item.account_name || '-';
                    const toName = item.transfer_to_account_name || '-';
                    return `${fromName} → ${toName}`;
                }

                return item.account_name || '-';
            }

            function getAmountClass(type) {
                if (type === 'income') return 'text-emerald-700';
                if (type === 'expense') return 'text-rose-700';
                return 'text-stone-800';
            }

            function getAmountPrefix(type) {
                if (type === 'income') return '+ ';
                if (type === 'expense') return '- ';
                return '';
            }
        %>

		<% if (success_msg && success_msg.length > 0) { %>
		<div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
			<%= success_msg[0] %>
		</div>
		<% } %>

		<% if (error_msg && error_msg.length > 0) { %>
		<div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
			<%= error_msg[0] %>
		</div>
		<% } %>

