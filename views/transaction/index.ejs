		<section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
			<div class="border-b border-stone-100 bg-gradient-to-r from-emerald-50 via-white to-amber-50 px-5 py-5 sm:px-7 sm:py-6">
				<div class="flex flex-col gap-4 xl:flex-row xl:items-center">
	
				<!-- LEFT -->
				<div>
					<div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 shadow-sm">
						Transaction History
					</div>
					<h1 class="mt-4 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">
						Manage Your Transactions
					</h1>
					<p class="mt-2 text-sm leading-7 text-stone-600">
						Your recorded money movement from the database.
					</p>
				</div>

				<!-- RIGHT (FIXED) -->
				<div class="flex flex-col gap-3 sm:flex-row sm:items-center ml-auto">
					
					<a
						href="/export/transactions/csv"
						class="inline-flex items-center justify-center gap-2 rounded-2xl border border-stone-200 bg-white px-5 py-3 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-200 hover:text-emerald-700"
					>
						<span>⇩</span>
						<span>Export CSV</span>
					</a>

					<a
						href="/transaction/create"
						class="inline-flex items-center justify-center gap-2 rounded-2xl bg-stone-900 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-stone-300/40 transition hover:-translate-y-0.5 hover:bg-emerald-700"
					>
						<span>＋</span>
						<span>Add Transaction</span>
					</a>

				</div>
			</div>
			</div>

			<div class="px-5 py-6 sm:px-7 sm:py-7">
				<form method="GET" action="/transaction" class="mb-5 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-[1fr_1fr_auto_auto]">
					<div class="min-w-0">
						<label class="mb-2 block text-sm font-semibold text-stone-800">From Date</label>
						<input
							type="date"
							name="from_date"
							value="<%= safeFilters.from_date %>"
							class="w-full min-w-0 rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
						>
					</div>

					<div class="min-w-0">
						<label class="mb-2 block text-sm font-semibold text-stone-800">To Date</label>
						<input
							type="date"
							name="to_date"
							value="<%= safeFilters.to_date %>"
							class="w-full min-w-0 rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
						>
					</div>

					<div class="flex items-end">
						<a
							href="/transaction"
							class="inline-flex h-[50px] w-full items-center justify-center rounded-2xl border border-stone-200 bg-white px-5 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-stone-300 md:w-auto"
						>
							Clear Filter
						</a>
					</div>

					<div class="flex items-end">
						<button
							type="submit"
							class="inline-flex h-[50px] w-full items-center justify-center rounded-2xl bg-stone-900 px-5 text-sm font-semibold text-white shadow-lg shadow-stone-300/30 transition hover:-translate-y-0.5 hover:bg-emerald-700 md:w-auto"
						>
							Apply Filter
						</button>
					</div>
				</form>

				<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
					<div>
						<p class="text-base font-semibold text-stone-900">Transaction List</p>
						<p class="mt-1 text-sm text-stone-500">Showing real transaction rows from your database</p>
					</div>

					<div class="inline-flex rounded-2xl border border-stone-200 bg-stone-50 p-1">
						<button
							type="button"
							id="table-view-btn"
							class="rounded-xl bg-white px-4 py-2 text-sm font-semibold text-stone-900 shadow-sm"
						>
							Table
						</button>
						<button
							type="button"
							id="card-view-btn"
							class="rounded-xl px-4 py-2 text-sm font-semibold text-stone-500"
						>
							Cards
						</button>
					</div>
				</div>
			</div>

			<div id="transaction-table-view" class="hidden lg:block">
				<div class="overflow-x-auto">
					<table class="min-w-full border-collapse">
						<thead>
							<tr class="border-b border-stone-200 bg-stone-50">
								<th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Date</th>
								<th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Description</th>
								<th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Type</th>
								<th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Category</th>
								<th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Account</th>
								<th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Amount</th>
								<th class="px-6 py-4 text-center text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Action</th>
							</tr>
						</thead>
						<tbody>
							<% if (safeTransactions.length === 0) { %>
							<tr>
								<td colspan="7" class="px-6 py-12 text-center text-sm text-stone-500">
									No transactions found yet. Start by creating your first transaction.
								</td>
							</tr>
							<% } %>

							<% safeTransactions.forEach((item) => { %>
							<tr class="border-b border-stone-100 last:border-b-0 hover:bg-stone-50/70">
								<td class="px-6 py-4 text-sm text-stone-500">
									<%= formatDateWib(item.transaction_date) %>
								</td>

								<td class="px-6 py-4 align-top">
									<p class="font-semibold text-stone-900"><%= getDisplayDescription(item) %></p>
									<p class="mt-1 text-xs text-stone-500"><%= item.reference_no || 'No reference' %></p>
								</td>

								<td class="px-6 py-4">
									<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= getTypeBadgeClass(item.transaction_type) %>">
										<%= getTypeLabel(item.transaction_type) %>
									</span>
								</td>

								<td class="px-6 py-4 text-sm text-stone-800">
									<%= getDisplayCategory(item) %>
								</td>

								<td class="px-6 py-4 text-sm text-stone-800">
									<%= getDisplayAccount(item) %>
								</td>

								<td class="px-6 py-4 text-right text-sm font-semibold <%= getAmountClass(item.transaction_type) %> whitespace-nowrap">
									<%= getAmountPrefix(item.transaction_type) %><%= formatCurrency(item.amount) %>
								</td>

								<td class="px-6 py-4">
									<div class="flex items-center justify-center gap-2">
										<a
											href="/transaction/<%= item.id %>/edit"
											class="rounded-xl border border-stone-200 bg-white px-3 py-2 text-xs font-semibold text-stone-700 transition hover:bg-stone-50"
										>
											Edit
										</a>

										<form action="/transaction/<%= item.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this transaction?');">
											<button
												type="submit"
												class="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-700 transition hover:bg-rose-100"
											>
												Delete
											</button>
										</form>
									</div>
								</td>
							</tr>
							<% }) %>
						</tbody>
					</table>
				</div>
			</div>

			<div id="transaction-card-view" class="space-y-4 p-5 sm:p-6 lg:hidden">
				<% if (safeTransactions.length === 0) { %>
				<div class="rounded-[24px] border border-stone-200 bg-stone-50 p-6 text-center text-sm text-stone-500">
					No transactions found yet. Start by creating your first transaction.
				</div>
				<% } %>

				<% safeTransactions.forEach((item) => { %>
				<div class="rounded-[28px] border border-stone-200 bg-white p-4 shadow-sm">
					<div class="flex items-start justify-between gap-4">
						<div>
							<p class="text-xs uppercase tracking-[0.14em] text-stone-500"><%= formatDateWib(item.transaction_date) %></p>
							<h3 class="mt-2 text-base font-semibold text-stone-900"><%= getDisplayDescription(item) %></h3>
							<p class="mt-1 text-sm text-stone-500"><%= item.reference_no || 'No reference' %></p>
						</div>

						<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= getTypeBadgeClass(item.transaction_type) %>">
							<%= getTypeLabel(item.transaction_type) %>
						</span>
					</div>

					<div class="mt-4 grid grid-cols-2 gap-3">
						<div class="rounded-2xl bg-stone-50 p-3">
							<p class="text-xs text-stone-500">Category</p>
							<p class="mt-1 text-sm font-semibold text-stone-900"><%= getDisplayCategory(item) %></p>
						</div>

						<div class="rounded-2xl bg-stone-50 p-3">
							<p class="text-xs text-stone-500">Account</p>
							<p class="mt-1 text-sm font-semibold text-stone-900"><%= getDisplayAccount(item) %></p>
						</div>
					</div>

					<div class="mt-4 flex items-center justify-between gap-4">
						<p class="text-sm font-semibold <%= getAmountClass(item.transaction_type) %> whitespace-nowrap">
							<%= getAmountPrefix(item.transaction_type) %><%= formatCurrency(item.amount) %>
						</p>

						<div class="flex gap-2">
							<a
								href="/transaction/<%= item.id %>/edit"
								class="rounded-xl border border-stone-200 bg-white px-3 py-2 text-xs font-semibold text-stone-700"
							>
								Edit
							</a>

							<form action="/transaction/<%= item.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this transaction?');">
								<button
									type="submit"
									class="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-700"
								>
									Delete
								</button>
							</form>
						</div>
					</div>
				</div>
				<% }) %>
			</div>

			<div class="flex flex-col gap-3 border-t border-stone-200 px-5 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-7 sm:py-6">
				<p class="text-sm text-stone-500">
					Showing <span class="font-semibold text-stone-900 whitespace-nowrap"><%= startRow %> - <%= endRow %></span> of <span class="font-semibold text-stone-900 whitespace-nowrap"><%= totalRows %></span> transactions
				</p>

				<div class="flex flex-wrap items-center gap-2">
					<% if (currentPage > 1) { %>
					<a
						href="/transaction?page=<%= currentPage - 1 %>&from_date=<%= encodeURIComponent(safeFilters.from_date || '') %>&to_date=<%= encodeURIComponent(safeFilters.to_date || '') %>"
						class="rounded-xl border border-stone-200 bg-white px-4 py-2 text-sm font-semibold text-stone-700 shadow-sm"
					>
						Prev
					</a>
					<% } else { %>
					<span class="rounded-xl border border-stone-200 bg-stone-50 px-4 py-2 text-sm font-semibold text-stone-400">
						Prev
					</span>
					<% } %>

					<% for (let i = 1; i <= totalPages; i += 1) { %>
					<% if (i === currentPage) { %>
					<span class="rounded-xl bg-stone-900 px-4 py-2 text-sm font-semibold text-white shadow-sm">
						<%= i %>
					</span>
					<% } else { %>
					<a
						href="/transaction?page=<%= i %>&from_date=<%= encodeURIComponent(safeFilters.from_date || '') %>&to_date=<%= encodeURIComponent(safeFilters.to_date || '') %>"
						class="rounded-xl border border-stone-200 bg-white px-4 py-2 text-sm font-semibold text-stone-700 shadow-sm"
					>
						<%= i %>
					</a>
					<% } %>
					<% } %>

					<% if (currentPage < totalPages) { %>
					<a
						href="/transaction?page=<%= currentPage + 1 %>&from_date=<%= encodeURIComponent(safeFilters.from_date || '') %>&to_date=<%= encodeURIComponent(safeFilters.to_date || '') %>"
						class="rounded-xl border border-stone-200 bg-white px-4 py-2 text-sm font-semibold text-stone-700 shadow-sm"
					>
						Next
					</a>
					<% } else { %>
					<span class="rounded-xl border border-stone-200 bg-stone-50 px-4 py-2 text-sm font-semibold text-stone-400">
						Next
					</span>
					<% } %>
				</div>
			</div>
		</section>
	</main>

	<script>
		const sidebarToggle = document.getElementById('sidebar-toggle');
		const sidebar = document.getElementById('app-sidebar');
		const overlay = document.getElementById('app-overlay');

		if (sidebarToggle && sidebar && overlay) {
			sidebarToggle.addEventListener('click', () => {
				sidebar.classList.toggle('show');
				overlay.classList.toggle('show');
			});

			overlay.addEventListener('click', () => {
				sidebar.classList.remove('show');
				overlay.classList.remove('show');
			});
		}

		const tableViewBtn = document.getElementById('table-view-btn');
		const cardViewBtn = document.getElementById('card-view-btn');
		const tableView = document.getElementById('transaction-table-view');
		const cardView = document.getElementById('transaction-card-view');

		if (tableViewBtn && cardViewBtn && tableView && cardView) {
			tableViewBtn.addEventListener('click', () => {
				tableView.classList.remove('hidden');
				cardView.classList.add('hidden');

				tableViewBtn.classList.add('bg-white', 'text-stone-900', 'shadow-sm');
				tableViewBtn.classList.remove('text-stone-500');

				cardViewBtn.classList.remove('bg-white', 'text-stone-900', 'shadow-sm');
				cardViewBtn.classList.add('text-stone-500');
			});

			cardViewBtn.addEventListener('click', () => {
				tableView.classList.add('hidden');
				cardView.classList.remove('hidden');

				cardViewBtn.classList.add('bg-white', 'text-stone-900', 'shadow-sm');
				cardViewBtn.classList.remove('text-stone-500');

				tableViewBtn.classList.remove('bg-white', 'text-stone-900', 'shadow-sm');
				tableViewBtn.classList.add('text-stone-500');
			});
		}
	</script>
</body>

</html>