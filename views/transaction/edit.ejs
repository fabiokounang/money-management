<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/app_head') %>
</head>
<body class="min-h-screen bg-stone-50 text-stone-800">
    <%- include('../partials/sidebar') %>

    <div id="app-overlay" class="app-overlay lg:hidden"></div>

    <main class="app-main px-4 py-4 sm:px-6 sm:py-6">
        <%- include('../partials/topbar') %>

        <%
            const item = typeof transaction_item !== 'undefined' && transaction_item ? transaction_item : {};
            const safeIncomeCategories = Array.isArray(income_categories) ? income_categories : [];
            const safeExpenseCategories = Array.isArray(expense_categories) ? expense_categories : [];
            const safeAccounts = Array.isArray(accounts) ? accounts : [];
            const safeSubcategories = Array.isArray(subcategories) ? subcategories : [];

            function formatCurrency(value) {
                return 'Rp ' + Number(value || 0).toLocaleString('id-ID');
            }


            function getPreviewBadgeClass(type) {
                if (type === 'income') return 'bg-emerald-100 text-emerald-700';
                if (type === 'expense') return 'bg-rose-100 text-rose-700';
                return 'bg-amber-100 text-amber-700';
            }

            function getPreviewAmountClass(type) {
                if (type === 'income') return 'text-emerald-700';
                if (type === 'expense') return 'text-rose-700';
                return 'text-stone-900';
            }

            function getPreviewAmountPrefix(type) {
                if (type === 'income') return '+ ';
                if (type === 'expense') return '- ';
                return '';
            }
        %>

        <section class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1.6fr)_360px]">
            <div>
                <div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50 backdrop-blur">
                    <div class="border-b border-stone-100 bg-gradient-to-r from-amber-50 via-white to-emerald-50 px-5 py-5 sm:px-7 sm:py-6">
                        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                            <div>
                                <div class="inline-flex items-center gap-2 rounded-full border border-amber-200 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-amber-700 shadow-sm">
                                    Transaction
                                </div>

                                <h1 class="mt-4 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">
                                    Edit Transaction
                                </h1>

                                <p class="mt-2 max-w-2xl text-sm leading-7 text-stone-600">
                                    Update transaction details so history and reports stay accurate.
                                </p>
                            </div>

                            <a
                                href="/transaction"
                                class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-200 hover:text-emerald-700"
                            >
                                ← Back to Transactions
                            </a>
                        </div>
                    </div>

                    <div class="px-5 py-6 sm:px-7 sm:py-7">
                        <% if (typeof error !== 'undefined' && error) { %>
                            <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
                                <%= error %>
                            </div>
                        <% } %>

                        <form action="/transaction/<%= item.id %>?_method=PUT" method="POST" class="space-y-8">
                            <div class="rounded-[28px] border border-stone-200 bg-stone-50/70 p-5 sm:p-6">
                                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                                    <div class="flex items-start gap-3">
                                        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-100 to-amber-100 text-lg text-emerald-800">
                                            ✎
                                        </div>
                                        <div>
                                            <h2 class="text-base font-semibold text-stone-900">Transaction details</h2>
                                            <p class="mt-1 max-w-xl text-sm text-stone-500">
                                                Start with the account, then date and time, type, amount, and category when it applies.
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-7 space-y-8">
                                    <div>
                                        <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-400">Accounts</p>
                                        <p class="mb-4 text-xs text-stone-500">Choose the account first; for transfers, pick both from and to.</p>
                                        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
                                            <div>
                                                <label for="account_id" class="mb-2 block text-sm font-semibold text-stone-800">
                                                    From account
                                                </label>
                                                <select
                                                    id="account_id"
                                                    name="account_id"
                                                    class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                                    required
                                                >
                                                    <option value="">Select account</option>
                                                    <% safeAccounts.forEach((acc) => { %>
                                                        <option value="<%= acc.id %>" <%= Number(item.account_id) === Number(acc.id) ? 'selected' : '' %> style="white-space: nowrap;">
                                                            <%= acc.account_name %> - <%= acc.account_type %> - <%= formatCurrency(acc.current_balance) %>
                                                        </option>
                                                    <% }) %>
                                                </select>
                                            </div>
                                            <div id="transfer-account-wrapper" class="<%= item.transaction_type === 'transfer' ? '' : 'hidden' %>">
                                                <label for="transfer_to_account_id" class="mb-2 block text-sm font-semibold text-stone-800">
                                                    To account
                                                </label>
                                                <select
                                                    id="transfer_to_account_id"
                                                    name="transfer_to_account_id"
                                                    class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                                >
                                                    <option value="">Select destination account</option>
                                                    <% safeAccounts.forEach((acc) => { %>
                                                        <option value="<%= acc.id %>" <%= Number(item.transfer_to_account_id) === Number(acc.id) ? 'selected' : '' %> style="white-space: nowrap;">
                                                            <%= acc.account_name %> - <%= acc.account_type %> - <%= formatCurrency(acc.current_balance) %>
                                                        </option>
                                                    <% }) %>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="border-t border-stone-200/90 pt-8">
                                        <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-400">When</p>
                                        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                                            <div>
                                                <label for="transaction_date" class="mb-2 block text-sm font-semibold text-stone-800">
                                                    Date
                                                </label>
                                                <input
                                                    type="date"
                                                    id="transaction_date"
                                                    name="transaction_date"
                                                    class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                                    value="<%= toDateInputValueWib(item.transaction_date) %>"
                                                    required
                                                >
                                            </div>
                                            <div>
                                                <label for="transaction_time" class="mb-2 block text-sm font-semibold text-stone-800">
                                                    Time
                                                </label>
                                                <input
                                                    type="time"
                                                    id="transaction_time"
                                                    name="transaction_time"
                                                    class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                                    value="<%= (item.transaction_time ? String(item.transaction_time).slice(0, 5) : '') %>"
                                                    required
                                                >
                                            </div>
                                        </div>
                                    </div>

                                    <div class="border-t border-stone-200/90 pt-8">
                                        <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-400">Type, amount &amp; payment</p>
                                        <div class="grid grid-cols-1 gap-5 lg:grid-cols-3">
                                            <div>
                                                <label for="transaction_type" class="mb-2 block text-sm font-semibold text-stone-800">
                                                    Type
                                                </label>
                                                <select
                                                    id="transaction_type"
                                                    name="transaction_type"
                                                    class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                                    required
                                                >
                                                    <option value="">Select type</option>
                                                    <option value="income" <%= item.transaction_type === 'income' ? 'selected' : '' %>>Income</option>
                                                    <option value="expense" <%= item.transaction_type === 'expense' ? 'selected' : '' %>>Expense</option>
                                                    <option value="transfer" <%= item.transaction_type === 'transfer' ? 'selected' : '' %>>Transfer</option>
                                                </select>
                                            </div>
                                            <div>
                                                <label for="amount" class="mb-2 block text-sm font-semibold text-stone-800">
                                                    Amount
                                                </label>
                                                <input
                                                    type="number"
                                                    id="amount"
                                                    name="amount"
                                                    data-thousands-hint="true"
                                                    class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition placeholder:text-stone-400 focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                                    placeholder="0"
                                                    min="1"
                                                    step="0.01"
                                                    value="<%= item.amount ?? '' %>"
                                                    required
                                                >
                                                <p class="mt-2 text-xs leading-5 text-stone-500">
                                                    Positive number; type decides income, expense, or internal transfer.
                                                </p>
                                            </div>
                                            <div>
                                                <label for="payment_method" class="mb-2 block text-sm font-semibold text-stone-800">
                                                    Payment method
                                                </label>
                                                <select
                                                    id="payment_method"
                                                    name="payment_method"
                                                    class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                                    required
                                                >
                                                    <option value="">Select payment method</option>
                                                    <option value="cash" <%= item.payment_method === 'cash' ? 'selected' : '' %>>Cash</option>
                                                    <option value="bank_transfer" <%= item.payment_method === 'bank_transfer' ? 'selected' : '' %>>Bank Transfer</option>
                                                    <option value="debit_card" <%= item.payment_method === 'debit_card' ? 'selected' : '' %>>Debit Card</option>
                                                    <option value="credit_card" <%= item.payment_method === 'credit_card' ? 'selected' : '' %>>Credit Card</option>
                                                    <option value="qris" <%= item.payment_method === 'qris' ? 'selected' : '' %>>QRIS</option>
                                                    <option value="ewallet" <%= item.payment_method === 'ewallet' ? 'selected' : '' %>>E-Wallet</option>
                                                    <option value="other" <%= item.payment_method === 'other' ? 'selected' : '' %>>Other</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="border-t border-stone-200/90 pt-8">
                                        <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-400">Category</p>
                                        <p class="mb-4 text-xs text-stone-500">For transfers, category is not used.</p>
                                        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
                                            <div>
                                                <label for="category_id" class="mb-2 block text-sm font-semibold text-stone-800">
                                                    Category
                                                </label>
                                                <select
                                                    id="category_id"
                                                    name="category_id"
                                                    class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                                    data-income-categories='<%- JSON.stringify(safeIncomeCategories) %>'
                                                    data-expense-categories='<%- JSON.stringify(safeExpenseCategories) %>'
                                                    data-selected-category-id="<%= item.category_id || '' %>"
                                                >
                                                    <option value="">Select category</option>
                                                </select>
                                            </div>
                                            <div>
                                                <label for="subcategory_id" class="mb-2 block text-sm font-semibold text-stone-800">
                                                    Subcategory
                                                </label>
                                                <select
                                                    id="subcategory_id"
                                                    name="subcategory_id"
                                                    class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                                    data-selected-subcategory-id="<%= item.subcategory_id || '' %>"
                                                >
                                                    <option value="">Select subcategory</option>
                                                    <% safeSubcategories.forEach((subitem) => { %>
                                                        <option value="<%= subitem.id %>" <%= Number(item.subcategory_id) === Number(subitem.id) ? 'selected' : '' %>>
                                                            <%= subitem.subcategory_name %>
                                                        </option>
                                                    <% }) %>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="border-t border-stone-200/90 pt-8">
                                        <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-emerald-200 bg-emerald-50/50 px-4 py-3">
                                            <input
                                                type="checkbox"
                                                name="include_in_dashboard"
                                                value="1"
                                                <%= Number(item.include_in_dashboard || 0) === 1 ? 'checked' : '' %>
                                                class="mt-1 h-4 w-4 rounded border-stone-300 text-emerald-600"
                                            >
                                            <span class="text-sm text-stone-800">
                                                Include in dashboard income / expense totals
                                            </span>
                                        </label>
                                        <p class="mt-2 text-xs text-stone-500">Uncheck to keep the row in history but exclude it from dashboard totals.</p>
                                    </div>
                                </div>
                            </div>

                            <div class="rounded-[28px] border border-stone-200 bg-stone-50/70 p-5 sm:p-6">
                                <div class="flex items-center gap-3">
                                    <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-stone-200 text-lg text-stone-700">
                                        •
                                    </div>
                                    <div>
                                        <h2 class="text-base font-semibold text-stone-900">Additional Details</h2>
                                        <p class="mt-1 text-sm text-stone-500">
                                            Notes and reference numbers keep history clear.
                                        </p>
                                    </div>
                                </div>

                                <div class="mt-6 grid grid-cols-1 gap-5">
                                    <div>
                                        <label for="description" class="mb-2 block text-sm font-semibold text-stone-800">
                                            Description
                                        </label>
                                        <textarea
                                            id="description"
                                            name="description"
                                            rows="4"
                                            class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-4 text-sm text-stone-800 outline-none transition placeholder:text-stone-400 focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                            placeholder="Example: Lunch at cafe, freelance payment, electricity bill..."
                                        ><%= item.description || '' %></textarea>
                                    </div>

                                    <div>
                                        <label for="reference_no" class="mb-2 block text-sm font-semibold text-stone-800">
                                            Reference Number
                                        </label>
                                        <input
                                            type="text"
                                            id="reference_no"
                                            name="reference_no"
                                            class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition placeholder:text-stone-400 focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                                            placeholder="Optional reference number"
                                            value="<%= item.reference_no || '' %>"
                                        >
                                    </div>
                                </div>
                            </div>

                            <div class="flex flex-col gap-3 border-t border-stone-200 pt-6 sm:flex-row sm:items-center sm:justify-between">
                                <button
                                    type="submit"
                                    form="delete-transaction-form"
                                    class="inline-flex items-center justify-center rounded-2xl border border-rose-200 bg-rose-50 px-5 py-3 text-sm font-semibold text-rose-700 transition hover:bg-rose-100"
                                >
                                    Delete Transaction
                                </button>

                                <div class="flex flex-col gap-3 sm:flex-row">
                                    <a
                                        href="/transaction"
                                        class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-5 py-3 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-stone-300"
                                    >
                                        Cancel
                                    </a>

                                    <button
                                        type="submit"
                                        class="inline-flex items-center justify-center rounded-2xl bg-stone-900 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-stone-300/40 transition hover:-translate-y-0.5 hover:bg-emerald-700"
                                    >
                                        Update Transaction
                                    </button>
                                </div>
                            </div>
                        </form>

                        <form
                            id="delete-transaction-form"
                            action="/transaction/<%= item.id %>?_method=DELETE"
                            method="POST"
                            onsubmit="return confirm('Delete this transaction?');"
                        ></form>
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                <div class="rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40 sm:p-6">
                    <div class="flex items-center gap-3">
                        <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700">
                            ✦
                        </div>
                        <div>
                            <p class="text-base font-semibold text-stone-900">Transaction Meta</p>
                            <p class="mt-1 text-sm text-stone-500">Helpful context for this record.</p>
                        </div>
                    </div>

                    <div class="mt-5 space-y-4">
                        <div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
                            <p class="text-xs uppercase tracking-[0.14em] text-stone-500">Transaction ID</p>
                            <p class="mt-2 text-base font-semibold text-stone-900">#TRX-<%= item.id || '-' %></p>
                        </div>

                        <div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
                            <p class="text-xs uppercase tracking-[0.14em] text-stone-500">Created At</p>
                            <p class="mt-2 text-sm font-semibold text-stone-900"><%= formatDateTimeWib(item.created_at) %></p>
                        </div>

                        <div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
                            <p class="text-xs uppercase tracking-[0.14em] text-stone-500">Last Updated</p>
                            <p class="mt-2 text-sm font-semibold text-stone-900"><%= formatDateTimeWib(item.updated_at) %></p>
                        </div>
                    </div>
                </div>

                <div class="rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40 sm:p-6">
                    <div class="flex items-center gap-3">
                        <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-amber-100 text-amber-700">
                            ▣
                        </div>
                        <div>
                            <p class="text-base font-semibold text-stone-900">Preview</p>
                            <p class="mt-1 text-sm text-stone-500">How this transaction currently looks.</p>
                        </div>
                    </div>

                    <div class="mt-5 rounded-[28px] border border-stone-200 bg-gradient-to-br from-stone-900 to-stone-700 p-5 text-white shadow-lg">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="text-xs uppercase tracking-[0.14em] text-white/60"><%= item.transaction_type || '-' %></p>
                                <h3 class="mt-2 text-base font-semibold"><%= item.description || 'No description' %></h3>
                                <p class="mt-1 text-sm text-white/70"><%= item.payment_method || '-' %></p>
                            </div>

                            <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= getPreviewBadgeClass(item.transaction_type) %>">
                                <%= item.transaction_type || '-' %>
                            </span>
                        </div>

                        <div class="mt-4 grid grid-cols-2 gap-3">
                            <div class="rounded-2xl border border-white/10 bg-white/10 p-3 backdrop-blur">
                                <p class="text-xs uppercase tracking-wide text-white/60">Date</p>
                                <p class="mt-1 text-sm font-semibold">
                                    <%= toDateInputValueWib(item.transaction_date) || '-' %>
                                </p>
                            </div>
                            <div class="rounded-2xl border border-white/10 bg-white/10 p-3 backdrop-blur">
                                <p class="text-xs uppercase tracking-wide text-white/60">Amount</p>
                                <p class="mt-1 text-sm font-semibold <%= getPreviewAmountClass(item.transaction_type) %> whitespace-nowrap">
                                    <%= getPreviewAmountPrefix(item.transaction_type) %><%= formatCurrency(item.amount) %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40 sm:p-6">
                    <p class="text-base font-semibold text-stone-900">Editing Note</p>
                    <p class="mt-3 text-sm leading-7 text-stone-600">
                        When editing, keep date, category, accounts, and amount consistent so reports do not shift unexpectedly.
                    </p>
                </div>
            </div>
        </section>
    </main>

    <script>
        const sidebarToggle = document.getElementById('sidebar-toggle');
        const sidebar = document.getElementById('app-sidebar');
        const overlay = document.getElementById('app-overlay');

        if (sidebarToggle && sidebar && overlay) {
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
                overlay.classList.toggle('show');
            });

            overlay.addEventListener('click', () => {
                sidebar.classList.remove('show');
                overlay.classList.remove('show');
            });
        }

        const transactionType = document.getElementById('transaction_type');
        const transferAccountWrapper = document.getElementById('transfer-account-wrapper');
        const categoryField = document.getElementById('category_id');
        const subcategoryField = document.getElementById('subcategory_id');

        function fillCategoryOptions(type, selectedCategoryId) {
            if (!categoryField) {
                return;
            }

            const incomeCategories = JSON.parse(categoryField.dataset.incomeCategories || '[]');
            const expenseCategories = JSON.parse(categoryField.dataset.expenseCategories || '[]');

            let options = [];

            if (type === 'income') {
                options = incomeCategories;
            }

            if (type === 'expense') {
                options = expenseCategories;
            }

            categoryField.innerHTML = '<option value="">Select category</option>';

            options.forEach((entry) => {
                const option = document.createElement('option');
                option.value = entry.id;
                option.textContent = entry.category_name;

                if (Number(selectedCategoryId) === Number(entry.id)) {
                    option.selected = true;
                }

                categoryField.appendChild(option);
            });
        }

        async function loadSubcategories(categoryId, selectedSubcategoryId = 0) {
            if (!subcategoryField) {
                return;
            }

            subcategoryField.innerHTML = '<option value="">Select subcategory</option>';

            if (!categoryId) {
                return;
            }

            try {
                const response = await fetch(`/transaction/subcategories/${categoryId}`, {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                const result = await response.json();

                if (!result.success || !Array.isArray(result.data)) {
                    return;
                }

                result.data.forEach((entry) => {
                    const option = document.createElement('option');
                    option.value = entry.id;
                    option.textContent = entry.subcategory_name;

                    if (Number(selectedSubcategoryId) === Number(entry.id)) {
                        option.selected = true;
                    }

                    subcategoryField.appendChild(option);
                });
            } catch (error) {
                console.error('Failed to load subcategories:', error);
            }
        }

        async function updateTransactionFormState(isInitial = false) {
            if (!transactionType || !transferAccountWrapper || !categoryField || !subcategoryField) {
                return;
            }

            const selectedCategoryId = categoryField.dataset.selectedCategoryId || '';
            const selectedSubcategoryId = Number(subcategoryField.dataset.selectedSubcategoryId || 0);

            if (transactionType.value === 'transfer') {
                transferAccountWrapper.classList.remove('hidden');

                categoryField.disabled = true;
                subcategoryField.disabled = true;

                categoryField.classList.add('opacity-60');
                subcategoryField.classList.add('opacity-60');

                categoryField.innerHTML = '<option value="">Select category</option>';
                subcategoryField.innerHTML = '<option value="">Select subcategory</option>';
                return;
            }

            transferAccountWrapper.classList.add('hidden');

            categoryField.disabled = false;
            subcategoryField.disabled = false;

            categoryField.classList.remove('opacity-60');
            subcategoryField.classList.remove('opacity-60');

            fillCategoryOptions(transactionType.value, selectedCategoryId);

            if (isInitial && selectedCategoryId) {
                await loadSubcategories(selectedCategoryId, selectedSubcategoryId);
            } else {
                subcategoryField.innerHTML = '<option value="">Select subcategory</option>';
            }
        }

        if (transactionType) {
            transactionType.addEventListener('change', async () => {
                categoryField.dataset.selectedCategoryId = '';
                subcategoryField.dataset.selectedSubcategoryId = '';
                await updateTransactionFormState(false);
            });

            updateTransactionFormState(true);
        }

        if (categoryField) {
            categoryField.addEventListener('change', async () => {
                subcategoryField.dataset.selectedSubcategoryId = '';
                await loadSubcategories(categoryField.value, 0);
            });
        }
    </script>
</body>
</html>