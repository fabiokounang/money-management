<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/app_head') %>
</head>

<body class="min-h-screen bg-stone-50 text-stone-800">
  <%- include('../partials/sidebar') %>

  <div id="app-overlay" class="app-overlay lg:hidden"></div>

  <main class="app-main px-4 py-4 sm:px-6 sm:py-6">
    <%- include('../partials/topbar') %>

    <section class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1.6fr)_360px]">
      <div>
        <div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50 backdrop-blur">
          <div class="border-b border-stone-100 bg-gradient-to-r from-emerald-50 via-white to-amber-50 px-5 py-5 sm:px-7 sm:py-6">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 shadow-sm">
                  Transaction
                </div>
                <h1 class="mt-4 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">
                  Create New Transaction
                </h1>
                <p class="mt-2 max-w-2xl text-sm leading-7 text-stone-600">
                  Add income, expense, or transfer with clear, easy-to-read details.
                </p>
              </div>

              <a
                href="/transaction"
                class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-200 hover:text-emerald-700"
              >
                ← Back to Transactions
              </a>
            </div>
          </div>

          <div class="px-5 py-6 sm:px-7 sm:py-7">
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
              <%= error %>
            </div>
            <% } %>

            <form action="/transaction" method="POST" class="space-y-8">
              <div class="rounded-[28px] border border-stone-200 bg-stone-50/70 p-5 sm:p-6">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div class="flex items-start gap-3">
                    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-100 to-amber-100 text-lg text-emerald-800">
                      ✎
                    </div>
                    <div>
                      <h2 class="text-base font-semibold text-stone-900">Transaction details</h2>
                      <p class="mt-1 max-w-xl text-sm text-stone-500">
                        Work top to bottom: when it happened, how much, then category and accounts.
                      </p>
                    </div>
                  </div>
                </div>

                <div class="mt-7 space-y-8">
                  <div>
                    <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-400">When</p>
                    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                      <div>
                        <label for="transaction_date" class="mb-2 block text-sm font-semibold text-stone-800">
                          Date
                        </label>
                        <input
                          type="date"
                          id="transaction_date"
                          name="transaction_date"
                          value="<%= (typeof prefill !== 'undefined' && prefill && prefill.transaction_date) ? prefill.transaction_date : '' %>"
                          class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                          required
                        >
                      </div>
                      <div>
                        <label for="transaction_time" class="mb-2 block text-sm font-semibold text-stone-800">
                          Time
                        </label>
                        <input
                          type="time"
                          id="transaction_time"
                          name="transaction_time"
                          value="<%= (typeof prefill !== 'undefined' && prefill && prefill.transaction_time) ? prefill.transaction_time : '' %>"
                          class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                          required
                        >
                      </div>
                    </div>
                  </div>

                  <div class="border-t border-stone-200/90 pt-8">
                    <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-400">Type, amount &amp; payment</p>
                    <div class="grid grid-cols-1 gap-5 lg:grid-cols-3">
                      <div>
                        <label for="transaction_type" class="mb-2 block text-sm font-semibold text-stone-800">
                          Type
                        </label>
                        <select
                          id="transaction_type"
                          name="transaction_type"
                          class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                          required
                        >
                          <option value="">Select type</option>
                          <option value="income" <%= (typeof prefill !== 'undefined' && prefill && prefill.transaction_type === 'income') ? 'selected' : '' %>>Income</option>
                          <option value="expense" <%= (typeof prefill !== 'undefined' && prefill && prefill.transaction_type === 'expense') ? 'selected' : '' %>>Expense</option>
                          <option value="transfer" <%= (typeof prefill !== 'undefined' && prefill && prefill.transaction_type === 'transfer') ? 'selected' : '' %>>Transfer</option>
                        </select>
                      </div>
                      <div>
                        <label for="amount" class="mb-2 block text-sm font-semibold text-stone-800">
                          Amount
                        </label>
                        <input
                          type="number"
                          id="amount"
                          name="amount"
                          data-thousands-hint="true"
                          class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition placeholder:text-stone-400 focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                          placeholder="0"
                          value="<%= (typeof prefill !== 'undefined' && prefill && prefill.amount) ? prefill.amount : '' %>"
                          min="1"
                          step="0.01"
                          required
                        >
                        <p class="mt-2 text-xs leading-5 text-stone-500">
                          Positive number; type decides income, expense, or internal transfer.
                        </p>
                      </div>
                      <div>
                        <label for="payment_method" class="mb-2 block text-sm font-semibold text-stone-800">
                          Payment method
                        </label>
                        <select
                          id="payment_method"
                          name="payment_method"
                          class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                          required
                        >
                          <option value="">Select payment method</option>
                          <option value="cash" <%= (typeof prefill !== 'undefined' && prefill && prefill.payment_method === 'cash') ? 'selected' : '' %>>Cash</option>
                          <option value="bank_transfer" <%= (typeof prefill !== 'undefined' && prefill && prefill.payment_method === 'bank_transfer') ? 'selected' : '' %>>Bank Transfer</option>
                          <option value="debit_card" <%= (typeof prefill !== 'undefined' && prefill && prefill.payment_method === 'debit_card') ? 'selected' : '' %>>Debit Card</option>
                          <option value="credit_card" <%= (typeof prefill !== 'undefined' && prefill && prefill.payment_method === 'credit_card') ? 'selected' : '' %>>Credit Card</option>
                          <option value="qris" <%= (typeof prefill !== 'undefined' && prefill && prefill.payment_method === 'qris') ? 'selected' : '' %>>QRIS</option>
                          <option value="ewallet" <%= (typeof prefill !== 'undefined' && prefill && prefill.payment_method === 'ewallet') ? 'selected' : '' %>>E-Wallet</option>
                          <option value="other" <%= (typeof prefill !== 'undefined' && prefill && prefill.payment_method === 'other') ? 'selected' : '' %>>Other</option>
                        </select>
                      </div>
                    </div>
                  </div>

                  <div class="border-t border-stone-200/90 pt-8">
                    <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-400">Category</p>
                    <p class="mb-4 text-xs text-stone-500">For transfers, category is not used—pick accounts below.</p>
                    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
                      <div>
                        <label for="category_id" class="mb-2 block text-sm font-semibold text-stone-800">
                          Category
                        </label>
                        <select
                          id="category_id"
                          name="category_id"
                          class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                          data-income-categories='<%- JSON.stringify(income_categories || []) %>'
                          data-expense-categories='<%- JSON.stringify(expense_categories || []) %>'
                        >
                          <option value="">Select category</option>
                        </select>
                      </div>
                      <div>
                        <label for="subcategory_id" class="mb-2 block text-sm font-semibold text-stone-800">
                          Subcategory
                        </label>
                        <select
                          id="subcategory_id"
                          name="subcategory_id"
                          class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                        >
                          <option value="">Select subcategory</option>
                        </select>
                      </div>
                    </div>
                  </div>

                  <div class="border-t border-stone-200/90 pt-8">
                    <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-400">Accounts</p>
                    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
                      <div>
                        <label for="account_id" class="mb-2 block text-sm font-semibold text-stone-800">
                          From account
                        </label>
                        <select
                          id="account_id"
                          name="account_id"
                          class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                          required
                        >
                          <option value="">Select account</option>
                          <% (accounts || []).forEach((item) => { %>
                          <option value="<%= item.id %>" <%= (typeof prefill !== 'undefined' && prefill && Number(prefill.account_id) === Number(item.id)) ? 'selected' : '' %>>
                            <%= item.account_name %> - <%= item.account_type %> - Rp <%= Number(item.current_balance || 0).toLocaleString('id-ID') %>
                          </option>
                          <% }) %>
                        </select>
                      </div>
                      <div id="transfer-account-wrapper" class="hidden">
                        <label for="transfer_to_account_id" class="mb-2 block text-sm font-semibold text-stone-800">
                          To account
                        </label>
                        <select
                          id="transfer_to_account_id"
                          name="transfer_to_account_id"
                          class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                        >
                          <option value="">Select destination account</option>
                          <% (accounts || []).forEach((item) => { %>
                          <option value="<%= item.id %>" <%= (typeof prefill !== 'undefined' && prefill && Number(prefill.transfer_to_account_id) === Number(item.id)) ? 'selected' : '' %>>
                            <%= item.account_name %> - <%= item.account_type %> - Rp <%= Number(item.current_balance || 0).toLocaleString('id-ID') %>
                          </option>
                          <% }) %>
                        </select>
                      </div>
                    </div>
                  </div>

                  <div class="border-t border-stone-200/90 pt-8">
                    <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-emerald-200 bg-emerald-50/50 px-4 py-3">
                      <input
                        type="checkbox"
                        name="include_in_dashboard"
                        value="1"
                        <%= (typeof prefill !== 'undefined' && prefill && Number(prefill.include_in_dashboard || 0) !== 1) ? '' : 'checked' %>
                        class="mt-1 h-4 w-4 rounded border-stone-300 text-emerald-600"
                      >
                      <span class="text-sm text-stone-800">
                        Include in dashboard income / expense totals
                      </span>
                    </label>
                    <p class="mt-2 text-xs text-stone-500">Uncheck to keep the row in history but exclude it from dashboard totals.</p>
                  </div>
                </div>
              </div>

              <div class="rounded-[28px] border border-stone-200 bg-stone-50/70 p-5 sm:p-6">
                <div class="flex items-center gap-3">
                  <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-stone-200 text-lg text-stone-700">
                    •
                  </div>
                  <div>
                    <h2 class="text-base font-semibold text-stone-900">Additional Details</h2>
                    <p class="mt-1 text-sm text-stone-500">
                      Add notes and a reference number if needed.
                    </p>
                  </div>
                </div>

                <div class="mt-6 grid grid-cols-1 gap-5">
                  <div>
                    <label for="description" class="mb-2 block text-sm font-semibold text-stone-800">
                      Description
                    </label>
                    <textarea
                      id="description"
                      name="description"
                      rows="4"
                      placeholder="Example: Lunch at cafe, freelance payment, electricity bill..."
                      class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-4 text-sm text-stone-800 outline-none transition placeholder:text-stone-400 focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                    ><%= (typeof prefill !== 'undefined' && prefill && prefill.description) ? prefill.description : '' %></textarea>
                  </div>

                  <div>
                    <label for="reference_no" class="mb-2 block text-sm font-semibold text-stone-800">
                      Reference Number
                    </label>
                    <input
                      type="text"
                      id="reference_no"
                      name="reference_no"
                      value="<%= (typeof prefill !== 'undefined' && prefill && prefill.reference_no) ? prefill.reference_no : '' %>"
                      class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition placeholder:text-stone-400 focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                      placeholder="Optional reference number"
                    >
                  </div>
                </div>
              </div>

              <div class="rounded-[28px] border border-indigo-200/90 bg-indigo-50/50 p-5 sm:p-6">
                <div class="flex items-center gap-3">
                  <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-indigo-100 text-lg text-indigo-700">
                    ↻
                  </div>
                  <div>
                    <h2 class="text-base font-semibold text-stone-900">Monthly schedule (optional)</h2>
                    <p class="mt-1 text-sm text-stone-600">
                      After this transaction is saved, the same amount and accounts can repeat automatically on the next due date (processed when you open the app).
                    </p>
                  </div>
                </div>

                <div class="mt-5 space-y-4">
                  <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-indigo-200 bg-white px-4 py-3">
                    <input type="checkbox" name="enable_monthly_schedule" value="1" class="mt-1 h-4 w-4 rounded border-stone-300 text-indigo-600">
                    <span class="text-sm text-stone-800">Also create a monthly recurring schedule from this template</span>
                  </label>

                  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    <div>
                      <label for="schedule_next_due_date" class="mb-2 block text-sm font-semibold text-stone-800">First scheduled posting date</label>
                      <input
                        type="date"
                        id="schedule_next_due_date"
                        name="schedule_next_due_date"
                        class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-indigo-400 focus:ring-4 focus:ring-indigo-100"
                      >
                      <p class="mt-1 text-xs text-stone-500">Must be after the transaction date above.</p>
                    </div>
                    <div>
                      <label for="schedule_interval_months" class="mb-2 block text-sm font-semibold text-stone-800">Every (months)</label>
                      <select
                        id="schedule_interval_months"
                        name="schedule_interval_months"
                        class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-indigo-400 focus:ring-4 focus:ring-indigo-100"
                      >
                        <% for (let m = 1; m <= 12; m += 1) { %>
                        <option value="<%= m %>" <%= m === 1 ? 'selected' : '' %>><%= m %> month<%= m > 1 ? 's' : '' %></option>
                        <% } %>
                      </select>
                    </div>
                  </div>

                  <div>
                    <label for="schedule_label" class="mb-2 block text-sm font-semibold text-stone-800">Schedule label (optional)</label>
                    <input
                      type="text"
                      id="schedule_label"
                      name="schedule_label"
                      maxlength="200"
                      class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-indigo-400 focus:ring-4 focus:ring-indigo-100"
                      placeholder="e.g. Netflix, Gym membership"
                    >
                  </div>
                </div>
              </div>

              <div class="flex flex-col gap-3 border-t border-stone-200 pt-6 sm:flex-row sm:justify-end">
                <a
                  href="/transaction"
                  class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-5 py-3 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-stone-300"
                >
                  Cancel
                </a>

                <button
                  type="submit"
                  class="inline-flex items-center justify-center rounded-2xl bg-stone-900 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-stone-300/40 transition hover:-translate-y-0.5 hover:bg-emerald-700"
                >
                  Save Transaction
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <div class="rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40 sm:p-6">
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700">
              ✦
            </div>
            <div>
              <p class="text-base font-semibold text-stone-900">Form Tips</p>
              <p class="mt-1 text-sm text-stone-500">A few small notes to keep your data clean.</p>
            </div>
          </div>

          <div class="mt-5 space-y-4">
            <div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
              <p class="text-sm font-semibold text-stone-900">Income</p>
              <p class="mt-1 text-sm leading-6 text-stone-600">
                Use for inflows like salary, bonuses, freelance, business income, and similar.
              </p>
            </div>

            <div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
              <p class="text-sm font-semibold text-stone-900">Expense</p>
              <p class="mt-1 text-sm leading-6 text-stone-600">
                Use for outflows like food, transport, bills, entertainment, and similar.
              </p>
            </div>

            <div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
              <p class="text-sm font-semibold text-stone-900">Transfer</p>
              <p class="mt-1 text-sm leading-6 text-stone-600">
                Use when money moves between accounts—not income or expense.
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40 sm:p-6">
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-amber-100 text-amber-700">
              ▣
            </div>
            <div>
              <p class="text-base font-semibold text-stone-900">Quick Preview</p>
              <p class="mt-1 text-sm text-stone-500">A soft preview of how this data may feel later.</p>
            </div>
          </div>

          <div class="mt-5 rounded-[28px] border border-stone-200 bg-gradient-to-br from-stone-900 to-stone-700 p-5 text-white shadow-lg">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs uppercase tracking-[0.14em] text-white/60">Example</p>
                <h3 class="mt-2 text-base font-semibold">Lunch at Cafe</h3>
                <p class="mt-1 text-sm text-white/70">Food • BCA • QRIS</p>
              </div>
              <span class="inline-flex rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700">
                Expense
              </span>
            </div>

            <div class="mt-4 grid grid-cols-2 gap-3">
              <div class="rounded-2xl border border-white/10 bg-white/10 p-3 backdrop-blur">
                <p class="text-xs uppercase tracking-wide text-white/60">Date</p>
                <p class="mt-1 text-sm font-semibold">2026-03-22</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/10 p-3 backdrop-blur">
                <p class="text-xs uppercase tracking-wide text-white/60">Amount</p>
                <p class="mt-1 text-sm font-semibold text-rose-200">- Rp 85.000</p>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40 sm:p-6">
          <p class="text-base font-semibold text-stone-900">Reminder</p>
          <p class="mt-3 text-sm leading-7 text-stone-600">
            Consistent entries matter more than perfect detail at first—get the core fields in cleanly.
          </p>
        </div>
      </div>
    </section>
  </main>

  <script type="application/json" id="tx-prefill-json"><%- JSON.stringify(typeof prefill !== 'undefined' ? prefill : null) %></script>

  <script>
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('app-sidebar');
    const overlay = document.getElementById('app-overlay');

    if (sidebarToggle && sidebar && overlay) {
      sidebarToggle.addEventListener('click', () => {
        sidebar.classList.toggle('show');
        overlay.classList.toggle('show');
      });

      overlay.addEventListener('click', () => {
        sidebar.classList.remove('show');
        overlay.classList.remove('show');
      });
    }

    const transactionType = document.getElementById('transaction_type');
    const transferAccountWrapper = document.getElementById('transfer-account-wrapper');
    const categoryField = document.getElementById('category_id');
    const subcategoryField = document.getElementById('subcategory_id');

    function resetSubcategoryOptions() {
      if (!subcategoryField) {
        return;
      }

      subcategoryField.innerHTML = '<option value="">Select subcategory</option>';
    }

    function fillCategoryOptions(type) {
      if (!categoryField) {
        return;
      }

      const incomeCategories = JSON.parse(categoryField.dataset.incomeCategories || '[]');
      const expenseCategories = JSON.parse(categoryField.dataset.expenseCategories || '[]');

      let options = [];

      if (type === 'income') {
        options = incomeCategories;
      }

      if (type === 'expense') {
        options = expenseCategories;
      }

      categoryField.innerHTML = '<option value="">Select category</option>';

      options.forEach((item) => {
        const option = document.createElement('option');
        option.value = item.id;
        option.textContent = item.category_name;
        categoryField.appendChild(option);
      });
    }

    async function loadSubcategories(categoryId) {
      resetSubcategoryOptions();

      if (!categoryId) {
        return;
      }

      try {
        const response = await fetch(`/transaction/subcategories/${categoryId}`, {
          method: 'GET',
          headers: {
            'Accept': 'application/json'
          }
        });

        const result = await response.json();

        if (!result.success || !Array.isArray(result.data)) {
          return;
        }

        result.data.forEach((item) => {
          const option = document.createElement('option');
          option.value = item.id;
          option.textContent = item.subcategory_name;
          subcategoryField.appendChild(option);
        });
      } catch (error) {
        console.error('Failed to load subcategories:', error);
      }
    }

    function updateTransactionFormState() {
      if (!transactionType || !transferAccountWrapper || !categoryField || !subcategoryField) {
        return;
      }

      if (transactionType.value === 'transfer') {
        transferAccountWrapper.classList.remove('hidden');

        categoryField.disabled = true;
        subcategoryField.disabled = true;

        categoryField.classList.add('opacity-60');
        subcategoryField.classList.add('opacity-60');

        categoryField.innerHTML = '<option value="">Select category</option>';
        resetSubcategoryOptions();
        return;
      }

      transferAccountWrapper.classList.add('hidden');

      categoryField.disabled = false;
      subcategoryField.disabled = false;

      categoryField.classList.remove('opacity-60');
      subcategoryField.classList.remove('opacity-60');

      fillCategoryOptions(transactionType.value);
      resetSubcategoryOptions();
    }

    if (transactionType) {
      transactionType.addEventListener('change', () => {
        updateTransactionFormState();
      });

      updateTransactionFormState();
    }

    if (categoryField) {
      categoryField.addEventListener('change', async () => {
        await loadSubcategories(categoryField.value);
      });
    }

    (async function applyPrefill() {
      const el = document.getElementById('tx-prefill-json');
      if (!el) {
        return;
      }

      let prefill = null;

      try {
        prefill = JSON.parse(el.textContent || 'null');
      } catch (e) {
        return;
      }

      if (!prefill || !transactionType) {
        return;
      }

      if (prefill.transaction_type) {
        transactionType.value = prefill.transaction_type;
        updateTransactionFormState();

        if (prefill.category_id && categoryField && (prefill.transaction_type === 'income' || prefill.transaction_type === 'expense')) {
          categoryField.value = String(prefill.category_id);
          await loadSubcategories(String(prefill.category_id));

          if (prefill.subcategory_id && subcategoryField) {
            subcategoryField.value = String(prefill.subcategory_id);
          }
        }
      }
    })();
  </script>
</body>

</html>