<aside id="app-sidebar" class="app-sidebar fixed inset-y-0 left-0 z-40 w-[290px] -translate-x-full overflow-y-auto lg:translate-x-0">
  <div class="flex min-h-full flex-col">
    <div class="px-5 pb-4 pt-5">
      <div class="rounded-3xl border border-white/70 bg-white/80 p-4 shadow-lg shadow-stone-200/40 backdrop-blur">
        <div class="flex items-center gap-3">
          <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-sage/20 text-lg font-bold text-sageDark">
            ₿
          </div>
          <div>
            <h1 class="text-base font-bold tracking-tight text-cocoa">Money Management</h1>
            <p class="text-xs text-muted">Finance made simple</p>
          </div>
        </div>

        <div class="mt-4 rounded-2xl border border-stone-200/80 bg-stone-50/80 px-3 py-2">
          <p class="text-[11px] uppercase tracking-[0.14em] text-muted">Signed in as</p>
          <p class="mt-1 text-sm font-semibold text-cocoa"><%= user ? user.full_name : 'User' %></p>
          <p class="text-xs text-muted"><%= user ? user.email : '-' %></p>
        </div>
      </div>
    </div>

    <nav class="flex-1 px-4 pb-5">
      <p class="px-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-muted/80">Main menu</p>
      <div class="mt-3 space-y-1.5">
        <a href="/dashboard" class="sidebar-link <%= current_path === '/dashboard' ? 'active' : '' %>">
          <span class="sidebar-icon">⌂</span>
          <span>Dashboard</span>
        </a>

        <a href="/transaction" class="sidebar-link <%= current_path.startsWith('/transaction') && !current_path.startsWith('/transaction/import') ? 'active' : '' %>">
          <span class="sidebar-icon">↔</span>
          <span>Transactions</span>
        </a>

        <a href="/transaction/import" class="sidebar-link <%= current_path.startsWith('/transaction/import') ? 'active' : '' %>">
          <span class="sidebar-icon">⤓</span>
          <span>Import CSV</span>
        </a>

        <a href="/recurring" class="sidebar-link <%= current_path.startsWith('/recurring') ? 'active' : '' %>">
          <span class="sidebar-icon">↻</span>
          <span>Scheduled</span>
        </a>

        <a href="/category" class="sidebar-link <%= current_path.startsWith('/category') ? 'active' : '' %>">
          <span class="sidebar-icon">◎</span>
          <span>Categories</span>
        </a>

        <a href="/subcategory" class="sidebar-link <%= current_path.startsWith('/subcategory') ? 'active' : '' %>">
          <span class="sidebar-icon">◌</span>
          <span>Subcategories</span>
        </a>

        <a href="/account" class="sidebar-link <%= current_path.startsWith('/account') ? 'active' : '' %>">
          <span class="sidebar-icon">◫</span>
          <span>Accounts</span>
        </a>

        <a href="/budget" class="sidebar-link <%= current_path.startsWith('/budget') ? 'active' : '' %>">
          <span class="sidebar-icon">▣</span>
          <span>Budgets</span>
        </a>
      </div>

      <div class="mt-7 rounded-3xl border border-white/70 bg-gradient-to-br from-white/95 via-white/80 to-[#f8f3ea] p-4 shadow-soft">
        <p class="text-sm font-semibold text-cocoa">Stay aware.</p>
        <p class="mt-2 text-xs leading-6 text-muted">
          Consistent daily tracking helps you make clearer financial decisions.
        </p>
      </div>
    </nav>

    <div class="border-t border-stone-200/70 px-4 py-4">
      <form action="/logout" method="POST">
        <button type="submit" class="sidebar-logout-btn">
          <span class="sidebar-icon">⤴</span>
          <span>Logout</span>
        </button>
      </form>
    </div>
  </div>
</aside>