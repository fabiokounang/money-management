        </p>
      </div>
    </nav>

    <!-- LOGOUT -->
    <div class="border-t border-stone-200/60 px-4 py-4">
      <form action="/logout" method="POST">
        <button type="submit" class="sidebar-logout-btn">
          <span class="sidebar-icon">⤴</span>
          <span>Logout</span>
        </button>
