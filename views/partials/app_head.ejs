<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title || 'Money Management' %></title>

<meta name="description" content="Modern and cozy money management app to track income, expense, and financial clarity.">
<meta name="theme-color" content="#f4f1ea">

<%- include('pwa_meta') %>

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<!-- Tailwind CDN -->
<script src="https://cdn.tailwindcss.com"></script>

<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          sans: ['Plus Jakarta Sans', 'ui-sans-serif', 'system-ui']
        },
        colors: {
          cream: '#f7f3ec',
          latte: '#efe7da',
          sage: '#7b9a7e',
          sageDark: '#5f7a62',
          cocoa: '#2d2a26',
          muted: '#726c64',
          lineSoft: '#e8e2d8',
          cardSoft: '#fffdf9',
          sand: '#f4f1ea',
          paper: '#fcfbf8',
          pine: '#2f5d50',
          pineSoft: '#e8f3ef',
          accent: '#b07d4f'
        },
        boxShadow: {
          soft: '0 12px 30px rgba(41, 36, 31, 0.08)',
          cozy: '0 30px 70px rgba(41, 36, 31, 0.12)'
        },
        borderRadius: {
          '4xl': '2rem'
        }
      }
    }
  }
</script>

<!-- App custom CSS -->
<link rel="stylesheet" href="/css/app.css">

<style>
  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    -webkit-tap-highlight-color: transparent;
    color: #2d2a26;
    background:
      radial-gradient(circle at 10% 0%, rgba(176, 125, 79, 0.10), transparent 30%),
      radial-gradient(circle at 95% 100%, rgba(47, 93, 80, 0.12), transparent 34%),
      linear-gradient(180deg, #f8f5ef 0%, #f4f1ea 52%, #f7f4ed 100%);
  }

  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-thumb {
    background: #d9d0c4;
    border-radius: 999px;
  }

  ::-webkit-scrollbar-track {
    background: transparent;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const numberInputs = document.querySelectorAll('input[type="number"]');
    numberInputs.forEach((input) => {
      if (input.dataset.formatHintAttached === '1') {
        return;
      }

      input.dataset.formatHintAttached = '1';
      const existingHint = input.parentElement
        ? input.parentElement.querySelector('.js-number-format-hint')
        : null;
      const hint = existingHint || document.createElement('p');
      if (!existingHint) {
        hint.className = 'js-number-format-hint mt-2 text-xs text-stone-500';
        input.insertAdjacentElement('afterend', hint);
      }

      const refreshHint = () => {
        const raw = String(input.value || '').trim();
        if (!raw) {
          hint.textContent = 'Auto-formats numbers like 1.000.000';
          return;
        }

        const parsed = Number(raw);
        if (!Number.isFinite(parsed)) {
          hint.textContent = 'Invalid number format.';
          return;
        }

        hint.textContent = `Preview: ${parsed.toLocaleString('id-ID')}`;
      };

      input.addEventListener('input', refreshHint);
      input.addEventListener('change', refreshHint);
      refreshHint();
    });
  });
</script>