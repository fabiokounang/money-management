<header class="app-topbar sticky top-0 z-30">
  <div class="topbar-shell flex items-center justify-between gap-3 sm:gap-4">
    <div class="flex min-w-0 items-center gap-3">
      <button
        type="button"
        id="sidebar-toggle"
        class="topbar-toggle inline-flex h-10 w-10 items-center justify-center rounded-2xl lg:hidden"
        aria-label="Toggle sidebar"
      >
        ☰
      </button>

      <div class="min-w-0">
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted">
          Workspace
        </p>
        <h2 class="truncate text-lg font-semibold tracking-tight text-cocoa sm:text-2xl">
          <%= title || 'Dashboard' %>
        </h2>
      </div>
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <div class="topbar-tip hidden items-center rounded-2xl px-4 py-2 text-sm text-muted sm:inline-flex">
        Keep it simple. Keep it consistent.
      </div>

      <div class="topbar-user flex items-center gap-3 rounded-2xl px-3 py-2">
        <div class="topbar-avatar flex h-10 w-10 items-center justify-center rounded-2xl font-semibold">
          <%= user && user.full_name ? user.full_name.charAt(0).toUpperCase() : 'U' %>
        </div>
        <div class="hidden leading-tight sm:block">
          <p class="text-sm font-semibold text-cocoa">
            <%= user ? user.full_name : 'User' %>
          </p>
          <p class="text-xs text-muted">
            <%= user ? user.email : 'user@email.com' %>
          </p>
        </div>
      </div>
    </div>
  </div>
</header>