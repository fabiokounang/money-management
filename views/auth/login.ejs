<!DOCTYPE html>
<html lang="en">

<head>
	<%- include('../partials/auth_head') %>
</head>

<body class="auth-bg text-stone-800">
	<div class="auth-shell relative flex min-h-screen overflow-hidden">
		<div class="pointer-events-none absolute inset-0">
			<div class="absolute -left-24 top-0 h-72 w-72 rounded-full bg-emerald-100/60 blur-3xl"></div>
			<div class="absolute right-0 top-1/4 h-80 w-80 rounded-full bg-amber-100/50 blur-3xl"></div>
			<div class="absolute bottom-0 left-1/3 h-72 w-72 rounded-full bg-lime-100/40 blur-3xl"></div>
		</div>

		<section class="relative hidden lg:flex lg:w-1/2">
			<div class="auth-panel flex w-full flex-col justify-between px-12 xl:px-16">
				<div>
					<!-- <div class="inline-flex items-center gap-3 rounded-full border border-emerald-200 bg-white/80 px-4 py-2 shadow-sm backdrop-blur">
						<span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
						<span class="text-sm font-semibold tracking-wide text-emerald-700">Money Management</span>
					</div> -->

					<div class="mt-12 max-w-xl">
						<p class="mb-4 text-sm font-semibold uppercase tracking-[0.24em] text-stone-500">
							Simple personal finance
						</p>

						<h1 class="text-3xl font-bold leading-tight tracking-tight text-stone-900 xl:text-3xl">
							Manage your money
							<span class="block text-emerald-700">with a calmer, clearer view.</span>
						</h1>

						<p class="mt-6 max-w-lg text-base leading-8 text-stone-600 xl:text-lg">
							Record income, expenses, and categories in a lighter, calmer interface you can use every day.
						</p>
					</div>

					<div class="mt-12 grid gap-4">
						<div class="rounded-3xl border border-stone-200/80 bg-white/80 p-5 shadow-sm shadow-stone-200/40 backdrop-blur">
							<div class="flex items-start gap-4">
								<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-emerald-50 text-lg font-bold text-emerald-700 shadow-inner">
									₿
								</div>
								<div>
									<h3 class="text-base font-semibold text-stone-900">Quick daily tracking</h3>
									<p class="mt-1 text-sm leading-6 text-stone-600">
										Log daily transactions with a clean layout that is easy on the eyes.
									</p>
								</div>
							</div>
						</div>

						<div class="rounded-3xl border border-stone-200/80 bg-white/80 p-5 shadow-sm shadow-stone-200/40 backdrop-blur">
							<div class="flex items-start gap-4">
								<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-amber-50 text-lg font-bold text-amber-700 shadow-inner">
									◎
								</div>
								<div>
									<h3 class="text-base font-semibold text-stone-900">Smarter category view</h3>
									<p class="mt-1 text-sm leading-6 text-stone-600">
										See which categories drive your spending the most.
									</p>
								</div>
							</div>
						</div>

						<div class="rounded-3xl border border-stone-200/80 bg-white/80 p-5 shadow-sm shadow-stone-200/40 backdrop-blur">
							<div class="flex items-start gap-4">
								<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-stone-100 text-lg font-bold text-stone-700 shadow-inner">
									↗
								</div>
								<div>
									<h3 class="text-base font-semibold text-stone-900">Built for clarity</h3>
									<p class="mt-1 text-sm leading-6 text-stone-600">
										Simple layout so you focus on the numbers, not visual noise.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- <div class="mt-10">
					<div class="rounded-3xl border border-stone-200/80 bg-white/75 p-5 shadow-sm backdrop-blur">
						<p class="text-sm leading-7 text-stone-600">
							“Small financial awareness, repeated every day, creates long-term control.”
						</p>
					</div>
				</div> -->
			</div>
		</section>

		<section class="relative flex w-full items-center justify-center px-5 py-8 sm:px-8 lg:w-1/2 lg:px-10">
			<div class="w-full max-w-md">
				<div class="mb-6 lg:hidden">
					<div class="inline-flex items-center gap-3 rounded-full border border-emerald-200 bg-white px-4 py-2 shadow-sm">
						<span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
						<span class="text-sm font-semibold tracking-wide text-emerald-700">Money Management</span>
					</div>
				</div>

				<div class="auth-form-card p-6 sm:p-8">
					<div>
						<p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Welcome back</p>
						<h2 class="mt-3 text-3xl font-bold tracking-tight text-stone-900">
							Login to your account
						</h2>
						<p class="mt-3 text-sm leading-7 text-stone-600">
							Sign in to open your dashboard, transactions, and insights.
						</p>
					</div>

					<% if (typeof error !== 'undefined' && error) { %>
					<div class="mt-5 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
						<%= error %>
					</div>
					<% } %>

					<% if (success_msg && success_msg.length > 0) { %>
					<div class="mt-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
						<%= success_msg[0] %>
					</div>
					<% } %>

					<% const loginOld = typeof old !== 'undefined' && old ? old : {}; %>

					<form action="/login" method="POST" class="mt-7 space-y-5">
						<div>
							<label for="login_id" class="mb-2 block text-sm font-semibold text-stone-800">
								Email or username
							</label>
							<input
								type="text"
								id="login_id"
								name="login_id"
								value="<%= loginOld.login_id || '' %>"
								placeholder="you@example.com or johndoe"
								autocomplete="username"
								required
								class="auth-input px-4 py-3 text-sm text-stone-800 placeholder:text-stone-400"
							>
						</div>

						<div>
							<div class="mb-2 flex items-center justify-between gap-3">
								<label for="password" class="block text-sm font-semibold text-stone-800">
									Password
								</label>
							</div>
							<input
								type="password"
								id="password"
								name="password"
								placeholder="Enter your password"
								autocomplete="current-password"
								required
								class="auth-input px-4 py-3 text-sm text-stone-800 placeholder:text-stone-400"
							>
							<p class="mt-2 text-xs leading-6 text-stone-500">
								Use your email or username and password.
							</p>
						</div>

						<button
							type="submit"
							class="auth-btn inline-flex w-full items-center justify-center px-4 py-3.5 text-sm font-semibold text-white"
						>
							Login
						</button>
					</form>

					<div class="mt-6 text-center text-sm text-stone-600">
						Don’t have an account?
						<a href="/register" class="font-semibold text-emerald-700 transition hover:text-emerald-800 hover:underline">
							Create account
						</a>
					</div>

				</div>
			</div>
		</section>
	</div>
</body>

</html>