<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/app_head') %>
</head>
<body class="min-h-screen bg-stone-50 text-stone-800">
  <%- include('../partials/sidebar') %>
  <div id="app-overlay" class="app-overlay lg:hidden"></div>

  <main class="app-main px-4 py-4 sm:px-6 sm:py-6">
    <%- include('../partials/topbar') %>

    <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
    <div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">
      <%= success_msg[0] %>
    </div>
    <% } %>

    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
    <div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-800">
      <%= error_msg[0] %>
    </div>
    <% } %>

    <section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
      <div class="border-b border-stone-100 bg-gradient-to-r from-sky-50 via-white to-emerald-50 px-5 py-5 sm:px-7 sm:py-6">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">Settings</p>
        <h1 class="mt-2 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">Test email (Gmail)</h1>
        <p class="mt-2 text-sm text-stone-600">Send a test message to your signed-in account using Nodemailer and Gmail SMTP.</p>
      </div>

      <div class="space-y-6 px-5 py-6 sm:px-7 sm:py-7">
        <div class="rounded-[24px] border border-stone-200 bg-stone-50/80 p-5">
          <p class="text-sm font-semibold text-stone-900">Configuration status</p>
          <% if (mail_ready) { %>
          <p class="mt-2 text-sm text-emerald-800"><code class="rounded bg-white px-1.5 py-0.5 text-xs">GMAIL_USER</code> and <code class="rounded bg-white px-1.5 py-0.5 text-xs">GMAIL_APP_PASSWORD</code> are set.</p>
          <% } else { %>
          <p class="mt-2 text-sm text-amber-900">Not ready: add the environment variables below (local <code class="rounded bg-white px-1.5 py-0.5 text-xs">.env</code>, or your host’s env UI in production).</p>
          <% } %>
        </div>

        <div class="rounded-[24px] border border-stone-200 bg-white p-5">
          <p class="text-sm font-semibold text-stone-900">Gmail (free) with an App Password</p>
          <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm leading-relaxed text-stone-700">
            <li>Turn on 2-Step Verification for your Google account.</li>
            <li>Open Google Account → Security → App passwords → create one for Mail (or “Other”).</li>
            <li>Copy the 16-character password (spaces are optional in <code class="text-xs">.env</code>).</li>
            <li>On the server, set:
              <ul class="mt-2 list-disc pl-5 text-xs text-stone-600">
                <li><code>GMAIL_USER</code> = your Gmail address (sender)</li>
                <li><code>GMAIL_APP_PASSWORD</code> = that app password</li>
                <li>Optional: <code>MAIL_FROM</code> if the From address should differ (defaults to <code>GMAIL_USER</code>)</li>
              </ul>
            </li>
            <li>Restart the app, then use the button below.</li>
          </ol>
        </div>

        <form method="POST" action="/settings/email/test" class="flex flex-wrap items-center gap-3">
          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-2xl bg-stone-900 px-6 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-emerald-700 disabled:cursor-not-allowed disabled:opacity-50"
            <%= mail_ready ? '' : 'disabled' %>
          >
            Send test to <%= user && user.email ? user.email : 'account email' %>
          </button>
          <a href="/dashboard" class="text-sm font-semibold text-emerald-700 underline decoration-emerald-700/30 underline-offset-2">Back to dashboard</a>
        </form>
      </div>
    </section>
  </main>
</body>
</html>
