<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/app_head') %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="min-h-screen bg-stone-50 text-stone-800">
  <%- include('../partials/sidebar') %>

  <div id="app-overlay" class="app-overlay lg:hidden"></div>

  <main class="app-main px-4 py-4 sm:px-6 sm:py-6">
    <%- include('../partials/topbar') %>

    <%
      const safeSummary = summary || {
        total_income: 0,
        total_expense: 0,
        total_transfer: 0,
        net_balance: 0,
        selected_categories_total: 0
      };

      const safeAccounts = Array.isArray(accounts) ? accounts : [];
      const safeCategories = Array.isArray(categories) ? categories : [];
      const safeCategorySummary = Array.isArray(category_summary) ? category_summary : [];
      const safeMonthlyCashflow = Array.isArray(monthly_cashflow) ? monthly_cashflow : [];
      const safeFilters = filters || {
        from_date: '',
        to_date: '',
        transaction_type: '',
        account_id: 0,
        category_ids: []
      };

      function formatCurrency(value) {
        return 'Rp ' + Number(value || 0).toLocaleString('id-ID');
      }

      const pieLabels = safeCategorySummary
        .filter((item) => item.category_type === 'expense')
        .map((item) => item.category_name);

      const pieValues = safeCategorySummary
        .filter((item) => item.category_type === 'expense')
        .map((item) => Number(item.total || 0));

      const barLabels = safeCategorySummary.map((item) => item.category_name);
      const barValues = safeCategorySummary.map((item) => Number(item.total || 0));

      const lineLabels = safeMonthlyCashflow.map((item) => item.month_label);
      const lineIncomeValues = safeMonthlyCashflow.map((item) => Number(item.total_income || 0));
      const lineExpenseValues = safeMonthlyCashflow.map((item) => Number(item.total_expense || 0));
    %>

    <section class="mt-6 grid grid-cols-1 gap-4 xl:grid-cols-4">
      <div class="rounded-[28px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-stone-500">Total Income</p>
            <h3 class="mt-3 text-3xl font-bold tracking-tight text-stone-900"><%= formatCurrency(safeSummary.total_income) %></h3>
            <p class="mt-2 text-xs text-emerald-600">Within selected period</p>
          </div>
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-lg font-semibold text-emerald-700">
            ↗
          </div>
        </div>
      </div>

      <div class="rounded-[28px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-stone-500">Total Expense</p>
            <h3 class="mt-3 text-3xl font-bold tracking-tight text-stone-900"><%= formatCurrency(safeSummary.total_expense) %></h3>
            <p class="mt-2 text-xs text-rose-600">Within selected period</p>
          </div>
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-rose-100 text-lg font-semibold text-rose-700">
            ↘
          </div>
        </div>
      </div>

      <div class="rounded-[28px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-stone-500">Net Balance</p>
            <h3 class="mt-3 text-3xl font-bold tracking-tight text-stone-900"><%= formatCurrency(safeSummary.net_balance) %></h3>
            <p class="mt-2 text-xs text-amber-700">Income minus expense</p>
          </div>
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-100 text-lg font-semibold text-amber-700">
            ◎
          </div>
        </div>
      </div>

      <div class="rounded-[28px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/40">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-stone-500">Selected Categories Total</p>
            <h3 class="mt-3 text-3xl font-bold tracking-tight text-stone-900"><%= formatCurrency(safeSummary.selected_categories_total) %></h3>
            <p class="mt-2 text-xs text-stone-500">Based on selected categories</p>
          </div>
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-stone-200 text-lg font-semibold text-stone-700">
            ▣
          </div>
        </div>
      </div>
    </section>

    <section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
      <div class="border-b border-stone-100 bg-gradient-to-r from-emerald-50 via-white to-amber-50 px-5 py-5 sm:px-7 sm:py-6">
        <div class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700 shadow-sm">
              Report Filters
            </div>
            <a
                href="/export/transactions/csv"
                class="inline-flex items-center justify-center gap-2 rounded-2xl border border-lineSoft bg-white px-5 py-3 text-sm font-semibold text-cocoa shadow-soft transition hover:-translate-y-[1px]"
            >
                <span>⇩</span>
                <span>Export CSV</span>
            </a>
            <h1 class="mt-4 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">
              Generate Financial Reports
            </h1>
            <p class="mt-2 text-sm leading-7 text-stone-600">
              Filter laporan berdasarkan tanggal, tipe transaksi, akun, dan kategori pilihan.
            </p>
          </div>
        </div>
      </div>

      <div class="px-5 py-6 sm:px-7 sm:py-7">
        <form method="GET" action="/report" class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
          <div>
            <label class="mb-2 block text-sm font-semibold text-stone-800">From Date</label>
            <input
              type="date"
              name="from_date"
              value="<%= safeFilters.from_date %>"
              class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
            >
          </div>

          <div>
            <label class="mb-2 block text-sm font-semibold text-stone-800">To Date</label>
            <input
              type="date"
              name="to_date"
              value="<%= safeFilters.to_date %>"
              class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
            >
          </div>

          <div>
            <label class="mb-2 block text-sm font-semibold text-stone-800">Transaction Type</label>
            <select
              name="transaction_type"
              class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
            >
              <option value="" <%= safeFilters.transaction_type === '' ? 'selected' : '' %>>All Type</option>
              <option value="income" <%= safeFilters.transaction_type === 'income' ? 'selected' : '' %>>Income</option>
              <option value="expense" <%= safeFilters.transaction_type === 'expense' ? 'selected' : '' %>>Expense</option>
              <option value="transfer" <%= safeFilters.transaction_type === 'transfer' ? 'selected' : '' %>>Transfer</option>
            </select>
          </div>

          <div>
            <label class="mb-2 block text-sm font-semibold text-stone-800">Account</label>
            <select
              name="account_id"
              class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
            >
              <option value="0">All Accounts</option>
              <% safeAccounts.forEach((item) => { %>
              <option value="<%= item.id %>" <%= Number(safeFilters.account_id) === Number(item.id) ? 'selected' : '' %>>
                <%= item.account_name %>
              </option>
              <% }) %>
            </select>
          </div>

          <div class="xl:col-span-2">
            <label class="mb-2 block text-sm font-semibold text-stone-800">Selected Categories</label>
            <select
              name="category_ids"
              multiple
              class="min-h-[120px] w-full rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm text-stone-800 outline-none transition focus:border-emerald-400 focus:bg-white focus:ring-4 focus:ring-emerald-100"
            >
              <% safeCategories.forEach((item) => { %>
              <option value="<%= item.id %>" <%= safeFilters.category_ids.includes(Number(item.id)) ? 'selected' : '' %>>
                <%= item.category_name %> (<%= item.category_type %>)
              </option>
              <% }) %>
            </select>
            <p class="mt-2 text-xs leading-5 text-stone-500">
              Pilih satu atau beberapa kategori untuk menghitung total kategori tertentu.
            </p>
          </div>

          <div class="md:col-span-2 xl:col-span-6 flex flex-col gap-3 sm:flex-row sm:justify-end">
            <a
              href="/report"
              class="inline-flex items-center justify-center rounded-2xl border border-stone-200 bg-white px-5 py-3 text-sm font-semibold text-stone-700 shadow-sm transition hover:-translate-y-0.5 hover:border-stone-300"
            >
              Reset Filter
            </a>

            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-2xl bg-stone-900 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-stone-300/40 transition hover:-translate-y-0.5 hover:bg-emerald-700"
            >
              Generate Report
            </button>
          </div>
        </form>
      </div>
    </section>

    <section class="mt-6 grid grid-cols-1 gap-6 2xl:grid-cols-3">
      <div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/50 sm:p-6">
        <div>
          <p class="text-base font-semibold text-stone-900">Expense by Category</p>
          <p class="mt-1 text-sm text-stone-500">Pie chart from real expense category totals</p>
        </div>

        <div class="mt-6 h-[320px] rounded-[24px] border border-stone-200 bg-stone-50 p-4">
          <canvas id="expensePieChart"></canvas>
        </div>
      </div>

      <div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/50 sm:p-6 2xl:col-span-2">
        <div>
          <p class="text-base font-semibold text-stone-900">Category Comparison</p>
          <p class="mt-1 text-sm text-stone-500">Bar chart from real category totals</p>
        </div>

        <div class="mt-6 h-[320px] rounded-[24px] border border-stone-200 bg-stone-50 p-4">
          <canvas id="categoryBarChart"></canvas>
        </div>
      </div>
    </section>

    <section class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-3">
      <div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/50 sm:p-6 xl:col-span-2">
        <div>
          <p class="text-base font-semibold text-stone-900">Income vs Expense Trend</p>
          <p class="mt-1 text-sm text-stone-500">Last 6 months from real transaction data</p>
        </div>

        <div class="mt-6 h-[340px] rounded-[24px] border border-stone-200 bg-stone-50 p-4">
          <canvas id="cashflowLineChart"></canvas>
        </div>
      </div>

      <div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 p-5 shadow-xl shadow-stone-200/50 sm:p-6">
        <div>
          <p class="text-base font-semibold text-stone-900">Quick Insights</p>
          <p class="mt-1 text-sm text-stone-500">Calculated from selected report data</p>
        </div>

        <div class="mt-6 space-y-4">
          <div class="rounded-[24px] border border-stone-200 bg-stone-50 p-4">
            <p class="text-xs uppercase tracking-[0.14em] text-stone-500">Highest Category</p>
            <p class="mt-2 text-lg font-bold text-stone-900">
              <%= safeCategorySummary.length > 0 ? safeCategorySummary[0].category_name : '-' %>
            </p>
            <p class="mt-1 text-sm text-stone-500">Category with the highest total in this report.</p>
          </div>

          <div class="rounded-[24px] border border-stone-200 bg-stone-50 p-4">
            <p class="text-xs uppercase tracking-[0.14em] text-stone-500">Selected Categories Total</p>
            <p class="mt-2 text-lg font-bold text-stone-900"><%= formatCurrency(safeSummary.selected_categories_total) %></p>
            <p class="mt-1 text-sm text-stone-500">Combined total from the selected categories.</p>
          </div>

          <div class="rounded-[24px] border border-stone-200 bg-stone-50 p-4">
            <p class="text-xs uppercase tracking-[0.14em] text-stone-500">Net Balance</p>
            <p class="mt-2 text-lg font-bold text-stone-900"><%= formatCurrency(safeSummary.net_balance) %></p>
            <p class="mt-1 text-sm text-stone-500">Difference between total income and expense.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
      <div class="border-b border-stone-100 px-5 py-5 sm:px-7 sm:py-6">
        <p class="text-base font-semibold text-stone-900">Category Summary Table</p>
        <p class="mt-1 text-sm text-stone-500">Detailed totals by category from real data</p>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full border-collapse">
          <thead>
            <tr class="border-b border-stone-200 bg-stone-50">
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Category</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Type</th>
              <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Total</th>
            </tr>
          </thead>
          <tbody>
            <% if (safeCategorySummary.length === 0) { %>
            <tr>
              <td colspan="3" class="px-6 py-12 text-center text-sm text-stone-500">
                No category summary data found for the selected filter.
              </td>
            </tr>
            <% } %>

            <% safeCategorySummary.forEach((item) => { %>
            <tr class="border-b border-stone-100 last:border-b-0 hover:bg-stone-50/70">
              <td class="px-6 py-4 font-semibold text-stone-900"><%= item.category_name %></td>
              <td class="px-6 py-4 text-sm text-stone-500 capitalize"><%= item.category_type %></td>
              <td class="px-6 py-4 text-right text-sm font-semibold text-stone-900"><%= formatCurrency(item.total) %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <script>
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('app-sidebar');
    const overlay = document.getElementById('app-overlay');

    if (sidebarToggle && sidebar && overlay) {
      sidebarToggle.addEventListener('click', () => {
        sidebar.classList.toggle('show');
        overlay.classList.toggle('show');
      });

      overlay.addEventListener('click', () => {
        sidebar.classList.remove('show');
        overlay.classList.remove('show');
      });
    }

    const pieCtx = document.getElementById('expensePieChart');
    if (pieCtx) {
      new Chart(pieCtx, {
        type: 'pie',
        data: {
          labels: <%- JSON.stringify(pieLabels) %>,
          datasets: [{
            data: <%- JSON.stringify(pieValues) %>
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'bottom'
            }
          }
        }
      });
    }

    const barCtx = document.getElementById('categoryBarChart');
    if (barCtx) {
      new Chart(barCtx, {
        type: 'bar',
        data: {
          labels: <%- JSON.stringify(barLabels) %>,
          datasets: [{
            label: 'Amount',
            data: <%- JSON.stringify(barValues) %>
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false
        }
      });
    }

    const lineCtx = document.getElementById('cashflowLineChart');
    if (lineCtx) {
      new Chart(lineCtx, {
        type: 'line',
        data: {
          labels: <%- JSON.stringify(lineLabels) %>,
          datasets: [
            {
              label: 'Income',
              data: <%- JSON.stringify(lineIncomeValues) %>,
              tension: 0.35
            },
            {
              label: 'Expense',
              data: <%- JSON.stringify(lineExpenseValues) %>,
              tension: 0.35
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false
        }
      });
    }
  </script>
</body>

</html>