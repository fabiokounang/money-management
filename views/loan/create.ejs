<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/app_head') %>
</head>
<body class="min-h-screen bg-stone-50 text-stone-800">
  <%- include('../partials/sidebar') %>
  <div id="app-overlay" class="app-overlay lg:hidden"></div>
  <main class="app-main px-4 py-4 sm:px-6 sm:py-6">
    <%- include('../partials/topbar') %>
    <section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white shadow-xl shadow-stone-200/50">
      <div class="border-b border-stone-100 px-5 py-5 sm:px-7 sm:py-6">
        <h1 class="text-2xl font-bold text-stone-900">Create loan entry</h1>
        <p class="mt-1 text-sm text-stone-600">Track receivable/payable with due date and outstanding.</p>
      </div>
      <div class="px-5 py-6 sm:px-7">
        <% if (error) { %><div class="mb-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div><% } %>
        <form action="/loan" method="POST" class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-semibold">Type</label>
            <select name="loan_type" required class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
              <option value="">Select type</option>
              <option value="receivable" <%= old.loan_type === 'receivable' ? 'selected' : '' %>>Receivable (someone owes me)</option>
              <option value="payable" <%= old.loan_type === 'payable' ? 'selected' : '' %>>Payable (I owe someone)</option>
            </select>
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold">Counterparty</label>
            <input name="counterparty_name" value="<%= old.counterparty_name || '' %>" required class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold">Principal amount</label>
            <input type="number" name="principal_amount" min="1" step="0.01" value="<%= old.principal_amount || '' %>" required class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold">Start date</label>
            <input type="date" name="start_date" value="<%= old.start_date || '' %>" required class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold">Due date (optional)</label>
            <input type="date" name="due_date" value="<%= old.due_date || '' %>" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold">Reminder days before due</label>
            <input type="number" name="reminder_days" min="0" step="1" value="<%= old.reminder_days || 0 %>" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm" />
          </div>
          <div class="md:col-span-2">
            <label class="mb-2 block text-sm font-semibold">Note</label>
            <textarea name="note" rows="3" maxlength="500" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm"><%= old.note || '' %></textarea>
          </div>
          <div class="md:col-span-2 flex gap-2 justify-end">
            <a href="/loan" class="rounded-2xl border border-stone-200 px-5 py-3 text-sm font-semibold text-stone-700">Cancel</a>
            <button class="rounded-2xl bg-stone-900 px-5 py-3 text-sm font-semibold text-white">Save entry</button>
          </div>
        </form>
      </div>
    </section>
  </main>
  <script>
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('app-sidebar');
    const overlay = document.getElementById('app-overlay');
    if (sidebarToggle && sidebar && overlay) {
      sidebarToggle.addEventListener('click', () => { sidebar.classList.toggle('show'); overlay.classList.toggle('show'); });
      overlay.addEventListener('click', () => { sidebar.classList.remove('show'); overlay.classList.remove('show'); });
    }
  </script>
</body>
</html>
