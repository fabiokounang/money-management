<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/app_head') %>
</head>
<body class="min-h-screen bg-stone-50 text-stone-800">
  <%- include('../partials/sidebar') %>
  <div id="app-overlay" class="app-overlay lg:hidden"></div>
  <main class="app-main px-4 py-4 sm:px-6 sm:py-6">
    <%- include('../partials/topbar') %>
    <%
      function money(v) { return 'Rp ' + Number(v || 0).toLocaleString('id-ID'); }
      const safePayments = Array.isArray(payments) ? payments : [];
      const safeAccounts = Array.isArray(accounts) ? accounts : [];
      function toDateTimeValue(dateValue, timeValue) {
        const datePart = String(dateValue || '').slice(0, 10);
        const timeRaw = String(timeValue || '00:00:00');
        const timePart = (timeRaw.length >= 8 ? timeRaw.slice(0, 8) : `${timeRaw}:00`).slice(0, 8);
        return `${datePart} ${timePart}`;
      }
    %>
    <section class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1.5fr)_380px]">
      <div class="overflow-hidden rounded-[32px] border border-stone-200/80 bg-white shadow-xl shadow-stone-200/50">
        <div class="border-b border-stone-100 px-5 py-5 sm:px-7 sm:py-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <h1 class="text-2xl font-bold text-stone-900"><%= item.counterparty_name %></h1>
              <p class="mt-1 text-sm text-stone-600"><%= item.loan_type === 'receivable' ? 'Receivable' : 'Payable' %> · Status: <span class="font-semibold"><%= item.status %></span></p>
            </div>
            <a href="/loan" class="rounded-2xl border border-stone-200 px-4 py-2 text-sm font-semibold text-stone-700">← Back</a>
          </div>
        </div>
        <div class="px-5 py-6 sm:px-7">
          <div class="grid grid-cols-2 gap-4">
            <div class="rounded-2xl bg-stone-50 p-4"><p class="text-xs text-stone-500">Principal</p><p class="mt-1 text-lg font-bold text-stone-900"><%= money(item.principal_amount) %></p></div>
            <div class="rounded-2xl bg-stone-50 p-4"><p class="text-xs text-stone-500">Outstanding</p><p class="mt-1 text-lg font-bold <%= Number(item.outstanding_amount) > 0 ? 'text-rose-700' : 'text-emerald-700' %>"><%= money(item.outstanding_amount) %></p></div>
            <div class="rounded-2xl bg-stone-50 p-4"><p class="text-xs text-stone-500">Start date</p><p class="mt-1 text-sm font-semibold text-stone-900"><%= item.start_date %></p></div>
            <div class="rounded-2xl bg-stone-50 p-4"><p class="text-xs text-stone-500">Due date</p><p class="mt-1 text-sm font-semibold text-stone-900"><%= item.due_date || '-' %></p></div>
          </div>
          <div class="mt-4 rounded-2xl border border-stone-200 p-4">
            <p class="text-xs text-stone-500">Note</p>
            <p class="mt-2 text-sm text-stone-700 break-words"><%= item.note || 'No note' %></p>
          </div>

          <div class="mt-4 rounded-2xl border border-stone-200 p-4">
            <p class="text-sm font-semibold text-stone-900">Payment history</p>
            <% if (safePayments.length === 0) { %>
              <p class="mt-3 text-sm text-stone-500">No payments yet.</p>
            <% } else { %>
              <div class="mt-3 space-y-2">
                <% safePayments.forEach((p) => { %>
                  <div class="rounded-2xl border border-stone-200 p-3">
                    <div class="flex items-center justify-between gap-2">
                      <p class="text-sm font-semibold text-stone-900"><%= money(p.amount) %></p>
                      <p class="text-xs text-stone-500"><%= formatDateTimeWib(toDateTimeValue(p.payment_date, p.payment_time)) %></p>
                    </div>
                    <p class="mt-1 text-xs text-stone-500 break-words"><%= p.note || '-' %></p>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <div class="rounded-[32px] border border-stone-200/80 bg-white p-5 shadow-xl shadow-stone-200/40 sm:p-6">
          <p class="text-base font-semibold text-stone-900">Add payment</p>
          <form method="POST" action="/loan/<%= item.id %>/payment" class="mt-4 space-y-3">
            <div>
              <label class="mb-2 block text-sm font-semibold">Amount</label>
              <input type="number" name="amount" min="0.01" step="0.01" required class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
            </div>
            <div>
              <label class="mb-2 block text-sm font-semibold">Payment date</label>
              <input type="date" name="payment_date" required class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
            </div>
            <div>
              <label class="mb-2 block text-sm font-semibold">Payment time</label>
              <input type="time" name="payment_time" required class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
            </div>
            <div>
              <label class="mb-2 block text-sm font-semibold">Note (optional)</label>
              <input type="text" name="note" maxlength="300" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
            </div>
            <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-emerald-200 bg-emerald-50/40 px-4 py-3">
              <input type="checkbox" name="create_transaction" value="1" class="mt-1 h-4 w-4 rounded border-stone-300 text-emerald-600">
              <span class="text-sm text-stone-800">Also create a transaction automatically</span>
            </label>
            <div>
              <label class="mb-2 block text-sm font-semibold">Destination account (for auto transaction)</label>
              <select name="account_id" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
                <option value="">Select account</option>
                <% safeAccounts.forEach((acc) => { %>
                  <option value="<%= acc.id %>"><%= acc.account_name %> - <%= acc.account_type %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="mb-2 block text-sm font-semibold">Payment method (auto transaction)</label>
              <select name="payment_method" class="w-full rounded-2xl border border-stone-200 px-4 py-3 text-sm">
                <option value="bank_transfer">Bank transfer</option>
                <option value="cash">Cash</option>
                <option value="debit_card">Debit card</option>
                <option value="credit_card">Credit card</option>
                <option value="qris">QRIS</option>
                <option value="ewallet">E-wallet</option>
                <option value="other">Other</option>
              </select>
            </div>
            <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3">
              <input type="checkbox" name="include_in_dashboard" value="1" class="mt-1 h-4 w-4 rounded border-stone-300 text-stone-700">
              <span class="text-sm text-stone-700">Include auto transaction in dashboard total income/expense</span>
            </label>
            <button class="w-full rounded-2xl bg-stone-900 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-700">Record payment</button>
          </form>
        </div>

      </div>
    </section>
  </main>
  <script>
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('app-sidebar');
    const overlay = document.getElementById('app-overlay');
    if (sidebarToggle && sidebar && overlay) {
      sidebarToggle.addEventListener('click', () => { sidebar.classList.toggle('show'); overlay.classList.toggle('show'); });
      overlay.addEventListener('click', () => { sidebar.classList.remove('show'); overlay.classList.remove('show'); });
    }
  </script>
</body>
</html>
