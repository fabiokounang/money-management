<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/app_head') %>
</head>
<body class="min-h-screen bg-stone-50 text-stone-800">
  <%- include('../partials/sidebar') %>
  <div id="app-overlay" class="app-overlay lg:hidden"></div>

  <main class="app-main px-4 py-4 sm:px-6 sm:py-6">
    <%- include('../partials/topbar') %>

    <% if (success_msg && success_msg.length > 0) { %>
    <div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
      <%= success_msg[0] %>
    </div>
    <% } %>

    <% if (error_msg && error_msg.length > 0) { %>
    <div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
      <%= error_msg[0] %>
    </div>
    <% } %>

    <section class="mt-6 overflow-hidden rounded-[32px] border border-stone-200/80 bg-white/90 shadow-xl shadow-stone-200/50">
      <div class="border-b border-stone-100 bg-gradient-to-r from-indigo-50 via-white to-emerald-50 px-5 py-5 sm:px-7 sm:py-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-indigo-700 shadow-sm">
              Recurring
            </div>
            <h1 class="mt-4 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">Scheduled transactions</h1>
            <p class="mt-2 text-sm text-stone-600">Templates post automatically on the due date when you open the app (dashboard or transactions).</p>
          </div>
          <a href="/recurring/create" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-stone-900 px-5 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-emerald-700">
            <span>＋</span> New schedule
          </a>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full border-collapse">
          <thead>
            <tr class="border-b border-stone-200 bg-stone-50">
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Next due</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Label / type</th>
              <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Amount</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Every</th>
              <th class="px-6 py-4 text-center text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Action</th>
            </tr>
          </thead>
          <tbody>
            <% const rows = Array.isArray(schedules) ? schedules : []; %>
            <% if (rows.length === 0) { %>
            <tr>
              <td colspan="5" class="px-6 py-12 text-center text-sm text-stone-500">No schedules yet. Create one from here or when saving a transaction.</td>
            </tr>
            <% } %>
            <% rows.forEach((s) => { %>
            <tr class="border-b border-stone-100 hover:bg-stone-50/70">
              <td class="px-6 py-4 text-sm font-medium text-stone-900"><%= String(s.next_due_date).slice(0, 10) %></td>
              <td class="px-6 py-4 text-sm text-stone-800">
                <div class="font-semibold"><%= s.label || s.description || '(no label)' %></div>
                <div class="mt-1 text-xs capitalize text-stone-500"><%= s.transaction_type %></div>
              </td>
              <td class="px-6 py-4 text-right text-sm font-semibold text-stone-900 whitespace-nowrap">Rp <%= Number(s.amount || 0).toLocaleString('id-ID') %></td>
              <td class="px-6 py-4 text-sm text-stone-600"><%= s.interval_months %> mo</td>
              <td class="px-6 py-4 text-center">
                <form action="/recurring/<%= s.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Remove this schedule?');">
                  <button type="submit" class="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-700">Remove</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% const tp = Math.max(Number(total_pages || 1), 1); const cp = Number(page || 1); %>
      <% if (tp > 1) { %>
      <div class="flex flex-wrap gap-2 border-t border-stone-200 px-5 py-4">
        <% for (let i = 1; i <= tp; i += 1) { %>
          <% if (i === cp) { %>
          <span class="rounded-xl bg-stone-900 px-4 py-2 text-sm font-semibold text-white"><%= i %></span>
          <% } else { %>
          <a href="/recurring?page=<%= i %>" class="rounded-xl border border-stone-200 bg-white px-4 py-2 text-sm font-semibold text-stone-700"><%= i %></a>
          <% } %>
        <% } %>
      </div>
      <% } %>
    </section>
  </main>

  <script>
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('app-sidebar');
    const overlay = document.getElementById('app-overlay');
    if (sidebarToggle && sidebar && overlay) {
      sidebarToggle.addEventListener('click', () => { sidebar.classList.toggle('show'); overlay.classList.toggle('show'); });
      overlay.addEventListener('click', () => { sidebar.classList.remove('show'); overlay.classList.remove('show'); });
    }
  </script>
</body>
</html>
